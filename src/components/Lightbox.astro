---
interface Photo {
  id: string;
  r2_key_medium: string;
  r2_key_full: string;
  city_name: string;
  capture_date?: string | null;
}

interface Props {
  photos: Photo[];
  mode: 'public' | 'private' | 'admin';
}

const { photos, mode } = Astro.props;
---

<div
  id="lightbox"
  class="fixed inset-0 z-50 bg-black select-none transition-opacity duration-200 ease-out opacity-0 pointer-events-none"
  data-mode={mode}
>
  <!-- Close button -->
  <button
    id="lightbox-close"
    class="absolute top-4 right-4 z-10 text-foreground/60 hover:text-foreground text-3xl leading-none p-2"
    aria-label="Close"
  >×</button>

  <!-- Edit icon (admin only) -->
  {mode === 'admin' && (
    <button
      id="lightbox-edit"
      class="absolute top-4 left-4 z-10 text-foreground/60 hover:text-foreground text-xl p-2"
      aria-label="Edit photo"
    >✎</button>
  )}

  <!-- Prev arrow -->
  <button
    id="lightbox-prev"
    class="absolute left-4 top-1/2 -translate-y-1/2 z-10 text-foreground/60 hover:text-foreground text-4xl p-4 transition-opacity opacity-40 hover:opacity-100"
    aria-label="Previous photo"
  >‹</button>

  <!-- Next arrow -->
  <button
    id="lightbox-next"
    class="absolute right-4 top-1/2 -translate-y-1/2 z-10 text-foreground/60 hover:text-foreground text-4xl p-4 transition-opacity opacity-40 hover:opacity-100"
    aria-label="Next photo"
  >›</button>

  <!-- Image wrapper — becomes scrollable in zoom mode -->
  <div id="lightbox-img-wrapper" class="absolute inset-0 flex items-center justify-center p-8 md:p-16">
    <img
      id="lightbox-img"
      src=""
      alt=""
      class="max-h-full max-w-full object-contain"
      draggable="false"
      oncontextmenu="return false;"
    />
  </div>

  <!-- Caption -->
  <div
    id="lightbox-city"
    class="absolute bottom-6 left-1/2 -translate-x-1/2 text-foreground/80 text-xs uppercase tracking-widest whitespace-nowrap"
  ></div>
</div>

<script define:vars={{ photos, mode }}>
  (function () {
    const lightbox = document.getElementById('lightbox');
    if (!lightbox) return;

    const imageWrapper = document.getElementById('lightbox-img-wrapper');
    const img = document.getElementById('lightbox-img');
    const cityLabel = document.getElementById('lightbox-city');
    const closeBtn = document.getElementById('lightbox-close');
    const prevBtn = document.getElementById('lightbox-prev');
    const nextBtn = document.getElementById('lightbox-next');
    const editBtn = document.getElementById('lightbox-edit');

    let _photos = Array.isArray(photos) ? photos.slice() : [];
    let currentIndex = -1;
    let isOpen = false;
    let zoomState = 'fit'; // 'fit' | 'zoomed'
    let isPanning = false;
    let panStart = { x: 0, y: 0, scrollLeft: 0, scrollTop: 0 };
    let mouseDownX = 0;
    let mouseDownY = 0;

    function preload(src) {
      if (!src) return;
      const i = new Image();
      i.src = src;
    }

    function formatCaption(photo) {
      const city = (photo.city_name || '').toUpperCase();
      if (!photo.capture_date) return city;
      const date = new Date(photo.capture_date);
      if (isNaN(date.getTime())) return city;
      const formatted = new Intl.DateTimeFormat('en-GB', {
        day: 'numeric',
        month: 'long',
        year: 'numeric'
      }).format(date).toUpperCase();
      return city ? `${city} · ${formatted}` : formatted;
    }

    function updateBoundaryHints() {
      const atFirst = currentIndex === 0;
      const atLast = currentIndex === _photos.length - 1;
      prevBtn.classList.toggle('!opacity-30', atFirst);
      prevBtn.classList.toggle('pointer-events-none', atFirst);
      nextBtn.classList.toggle('!opacity-30', atLast);
      nextBtn.classList.toggle('pointer-events-none', atLast);
    }

    function zoomIn(fracX, fracY) {
      zoomState = 'zoomed';

      img.src = `/i/${_photos[currentIndex].r2_key_full}`;

      imageWrapper.classList.remove('flex', 'items-center', 'justify-center', 'p-8', 'md:p-16');
      imageWrapper.classList.add('overflow-auto');
      imageWrapper.style.touchAction = 'pinch-zoom';

      img.classList.remove('max-h-full', 'max-w-full', 'object-contain');
      img.classList.add('cursor-grab');

      prevBtn.classList.add('hidden');
      nextBtn.classList.add('hidden');
      cityLabel.classList.add('hidden');

      function scrollToFrac() {
        if (fracX !== undefined && fracY !== undefined) {
          const scrollX = fracX * imageWrapper.scrollWidth - imageWrapper.clientWidth / 2;
          const scrollY = fracY * imageWrapper.scrollHeight - imageWrapper.clientHeight / 2;
          imageWrapper.scrollLeft = Math.max(0, scrollX);
          imageWrapper.scrollTop = Math.max(0, scrollY);
        } else {
          imageWrapper.scrollLeft = (imageWrapper.scrollWidth - imageWrapper.clientWidth) / 2;
          imageWrapper.scrollTop = (imageWrapper.scrollHeight - imageWrapper.clientHeight) / 2;
        }
      }

      if (img.complete && img.naturalWidth > 0) {
        requestAnimationFrame(scrollToFrac);
      } else {
        img.onload = () => { img.onload = null; requestAnimationFrame(scrollToFrac); };
      }
    }

    function zoomOut() {
      zoomState = 'fit';

      img.src = `/i/${_photos[currentIndex].r2_key_medium}`;

      imageWrapper.classList.remove('overflow-auto');
      imageWrapper.classList.add('flex', 'items-center', 'justify-center', 'p-8', 'md:p-16');
      imageWrapper.scrollLeft = 0;
      imageWrapper.scrollTop = 0;
      imageWrapper.style.touchAction = '';

      img.classList.remove('cursor-grab', 'cursor-grabbing');
      img.classList.add('max-h-full', 'max-w-full', 'object-contain');

      prevBtn.classList.remove('hidden');
      nextBtn.classList.remove('hidden');
      cityLabel.classList.remove('hidden');

      updateBoundaryHints();
    }

    function resetZoomDOM() {
      zoomState = 'fit';
      imageWrapper.classList.remove('overflow-auto');
      imageWrapper.classList.add('flex', 'items-center', 'justify-center', 'p-8', 'md:p-16');
      imageWrapper.scrollLeft = 0;
      imageWrapper.scrollTop = 0;
      imageWrapper.style.touchAction = '';
      img.classList.remove('cursor-grab', 'cursor-grabbing');
      img.classList.add('max-h-full', 'max-w-full', 'object-contain');
      prevBtn.classList.remove('hidden');
      nextBtn.classList.remove('hidden');
      cityLabel.classList.remove('hidden');
    }

    function showPhoto(index, pushHistory = true) {
      if (index < 0 || index >= _photos.length) return;

      if (zoomState === 'zoomed') resetZoomDOM();

      currentIndex = index;
      const photo = _photos[index];

      img.src = `/i/${photo.r2_key_medium}`;
      img.alt = photo.city_name || '';
      cityLabel.textContent = formatCaption(photo);

      // Silently upgrade to full variant once loaded
      const full = new Image();
      full.onload = () => {
        if (currentIndex === index && zoomState === 'fit') {
          img.src = `/i/${photo.r2_key_full}`;
        }
      };
      full.src = `/i/${photo.r2_key_full}`;

      if (index > 0) preload(`/i/${_photos[index - 1].r2_key_medium}`);
      if (index < _photos.length - 1) preload(`/i/${_photos[index + 1].r2_key_medium}`);

      updateBoundaryHints();

      if (pushHistory) {
        const newHash = `#photo=${photo.id}`;
        if (window.location.hash !== newHash) {
          if (isOpen) {
            history.replaceState({ lightbox: true }, '', newHash);
          } else {
            history.pushState({ lightbox: true }, '', newHash);
          }
        }
      }
    }

    function openAt(index) {
      if (index < 0 || index >= _photos.length) return;
      lightbox.classList.remove('pointer-events-none');
      document.body.style.overflow = 'hidden';
      showPhoto(index, true);
      isOpen = true;
      requestAnimationFrame(() => {
        lightbox.classList.remove('opacity-0');
      });
    }

    function close() {
      if (zoomState === 'zoomed') zoomState = 'fit';
      lightbox.classList.add('opacity-0');
      document.body.style.overflow = '';
      isOpen = false;
      currentIndex = -1;
      setTimeout(() => {
        if (!isOpen) lightbox.classList.add('pointer-events-none');
      }, 200);
      if (history.state?.lightbox === true) {
        history.back();
      } else if (window.location.hash.startsWith('#photo=')) {
        history.replaceState(null, '', window.location.pathname + window.location.search);
      }
    }

    function next() {
      if (currentIndex < _photos.length - 1) showPhoto(currentIndex + 1);
    }

    function prev() {
      if (currentIndex > 0) showPhoto(currentIndex - 1);
    }

    // Image click — toggle zoom (stopPropagation keeps it from bubbling to overlay)
    img.addEventListener('click', (e) => {
      e.stopPropagation();
      const moved = Math.abs(e.clientX - mouseDownX) > 5 || Math.abs(e.clientY - mouseDownY) > 5;
      if (moved) return;
      if (zoomState === 'fit') {
        const rect = img.getBoundingClientRect();
        const fracX = (e.clientX - rect.left) / rect.width;
        const fracY = (e.clientY - rect.top) / rect.height;
        zoomIn(fracX, fracY);
      } else {
        zoomOut();
      }
    });

    // Overlay click — close in fit mode
    lightbox.addEventListener('click', (e) => {
      if (zoomState === 'fit' && (e.target === lightbox || e.target === imageWrapper)) close();
    });

    // Pan when zoomed — mouse drag
    imageWrapper.addEventListener('mousedown', (e) => {
      mouseDownX = e.clientX;
      mouseDownY = e.clientY;
      if (zoomState !== 'zoomed') return;
      isPanning = true;
      panStart = {
        x: e.clientX,
        y: e.clientY,
        scrollLeft: imageWrapper.scrollLeft,
        scrollTop: imageWrapper.scrollTop
      };
      img.classList.remove('cursor-grab');
      img.classList.add('cursor-grabbing');
      e.preventDefault();
    });

    window.addEventListener('mousemove', (e) => {
      if (!isPanning) return;
      imageWrapper.scrollLeft = panStart.scrollLeft - (e.clientX - panStart.x);
      imageWrapper.scrollTop = panStart.scrollTop - (e.clientY - panStart.y);
    });

    window.addEventListener('mouseup', () => {
      if (!isPanning) return;
      isPanning = false;
      img.classList.remove('cursor-grabbing');
      if (zoomState === 'zoomed') img.classList.add('cursor-grab');
    });

    function bindClickHandlers() {
      document.querySelectorAll('[data-lightbox-id]:not([data-lb-bound])').forEach((el) => {
        el.dataset.lbBound = '1';
        el.addEventListener('click', (e) => {
          e.preventDefault();
          const id = el.getAttribute('data-lightbox-id');
          const index = _photos.findIndex((p) => p.id === id);
          if (index >= 0) openAt(index);
        });
        el.style.cursor = 'pointer';
      });
    }

    window.lightboxRefresh = function (newPhotos) {
      if (isOpen) {
        if (zoomState === 'zoomed') resetZoomDOM();
        lightbox.classList.add('opacity-0', 'pointer-events-none');
        document.body.style.overflow = '';
        isOpen = false;
        currentIndex = -1;
        if (window.location.hash.startsWith('#photo=')) {
          history.replaceState(null, '', window.location.pathname + window.location.search);
        }
      }
      _photos = Array.isArray(newPhotos) ? newPhotos.slice() : [];
      bindClickHandlers();
    };

    bindClickHandlers();

    closeBtn.addEventListener('click', close);
    prevBtn.addEventListener('click', prev);
    nextBtn.addEventListener('click', next);

    if (editBtn) {
      editBtn.addEventListener('click', () => {
        const photo = _photos[currentIndex];
        if (photo) {
          window.dispatchEvent(new CustomEvent('lightbox:edit', { detail: { photoId: photo.id } }));
        }
      });
    }

    document.addEventListener('keydown', (e) => {
      if (!isOpen) return;
      if (e.key === 'Escape') {
        const openDialog = document.querySelector('[role="dialog"]:not(.hidden)');
        if (openDialog) return;
        close();
      } else if (e.key === 'ArrowLeft' && zoomState === 'fit') {
        prev();
      } else if (e.key === 'ArrowRight' && zoomState === 'fit') {
        next();
      }
    });

    // Touch / swipe (fit mode only; zoom mode uses native scroll + pinch)
    let touchStartX = 0;
    let touchStartY = 0;
    lightbox.addEventListener('touchstart', (e) => {
      touchStartX = e.changedTouches[0].screenX;
      touchStartY = e.changedTouches[0].screenY;
    }, { passive: true });
    lightbox.addEventListener('touchend', (e) => {
      if (zoomState === 'zoomed') return;
      const touchEndX = e.changedTouches[0].screenX;
      const touchEndY = e.changedTouches[0].screenY;
      const deltaX = touchEndX - touchStartX;
      const deltaY = touchEndY - touchStartY;
      const absX = Math.abs(deltaX);
      const absY = Math.abs(deltaY);
      if (absY > absX && deltaY > 80) {
        close();
      } else if (absX > 50 && absX > absY) {
        if (deltaX < 0) next();
        else prev();
      }
    }, { passive: true });

    window.addEventListener('popstate', (e) => {
      if (isOpen && e.state?.lightbox !== true) {
        if (zoomState === 'zoomed') zoomState = 'fit';
        lightbox.classList.add('opacity-0');
        document.body.style.overflow = '';
        isOpen = false;
        currentIndex = -1;
        setTimeout(() => {
          if (!isOpen) lightbox.classList.add('pointer-events-none');
        }, 200);
      } else if (!isOpen && e.state?.lightbox === true) {
        openFromHash(false);
      }
    });

    function openFromHash(pushHistory) {
      const hash = window.location.hash;
      const match = hash.match(/^#photo=(.+)$/);
      if (!match) return;
      const id = match[1];
      const index = _photos.findIndex((p) => p.id === id);
      if (index >= 0) {
        if (isOpen) {
          showPhoto(index, pushHistory);
        } else {
          lightbox.classList.remove('pointer-events-none');
          document.body.style.overflow = 'hidden';
          showPhoto(index, pushHistory);
          isOpen = true;
          requestAnimationFrame(() => {
            lightbox.classList.remove('opacity-0');
          });
        }
      }
    }

    if (window.location.hash.startsWith('#photo=')) {
      openFromHash(false);
    }
  })();
</script>

<style>
  /* Force arrows visible on touch devices where hover never fires.
     Exclude boundary-hinted arrows — their !opacity-30 takes precedence. */
  @media (hover: none) {
    #lightbox-prev:not(.\!opacity-30),
    #lightbox-next:not(.\!opacity-30) {
      opacity: 1;
    }
  }
</style>
