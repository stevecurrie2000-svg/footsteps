---
const pathname = Astro.url.pathname;

function isActive(href: string) {
  if (href === "/admin") return pathname === "/admin";
  return pathname.startsWith(href);
}
---

<nav class="border-b border-white/5">
  <div class="mx-auto flex max-w-7xl items-center gap-6 px-6 py-2">
    <a
      href="/admin"
      class:list={["text-sm transition-colors", isActive("/admin") ? "text-foreground" : "text-foreground/40 hover:text-foreground/60"]}
    >Upload</a>
    <a
      href="/admin/photos"
      class:list={["text-sm transition-colors", isActive("/admin/photos") ? "text-foreground" : "text-foreground/40 hover:text-foreground/60"]}
    >Photos</a>
    <a
      href="/admin/countries"
      class:list={["text-sm transition-colors", isActive("/admin/countries") ? "text-foreground" : "text-foreground/40 hover:text-foreground/60"]}
    >Countries</a>
    <a
      href="/admin/access"
      class:list={["text-sm transition-colors", isActive("/admin/access") ? "text-foreground" : "text-foreground/40 hover:text-foreground/60"]}
    >Access</a>
  </div>
</nav>
