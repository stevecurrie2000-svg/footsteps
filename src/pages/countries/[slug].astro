---
import { env } from "cloudflare:workers";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Lightbox from "../../components/Lightbox.astro";

const { slug } = Astro.params;

// Fetch the country — 404 if the slug doesn't exist
const country = await env.DB
  .prepare(`SELECT c.id, c.slug, c.name, p.r2_key_medium AS thumbnail_r2_key_medium
            FROM countries c
            LEFT JOIN photos p ON p.id = c.public_thumbnail_photo_id
            WHERE c.slug = ?`)
  .bind(slug)
  .first<{ id: number; slug: string; name: string; thumbnail_r2_key_medium: string | null }>();

if (!country) {
  return new Response(null, { status: 404, statusText: "Not Found" });
}

// Fetch cities for this country
const { results: cities } = await env.DB
  .prepare("SELECT id, slug, name FROM cities WHERE country_id = ? ORDER BY id")
  .bind(country.id)
  .all<{ id: number; slug: string; name: string }>();

// Fetch public photos for this country, ordered for a consistent layout
const { results: photos } = await env.DB
  .prepare(`
    SELECT id, city_id, r2_key_thumb, r2_key_medium, r2_key_full, caption, width, height, capture_date
    FROM photos
    WHERE country_id = ? AND is_public = 1
    ORDER BY city_id, capture_date, created_at
  `)
  .bind(country.id)
  .all<{ id: string; city_id: number; r2_key_thumb: string; r2_key_medium: string; r2_key_full: string; caption: string | null; width: number | null; height: number | null; capture_date: string | null }>();

// Group photos by city_id so each city section can render its own grid
const photosByCity = new Map<number, typeof photos>();
for (const photo of photos) {
  const list = photosByCity.get(photo.city_id) ?? [];
  list.push(photo);
  photosByCity.set(photo.city_id, list);
}

const citiesWithPhotos = cities.filter(c => (photosByCity.get(c.id)?.length ?? 0) > 0);

// Build flat photos array in DOM order (cities by id, photos by capture_date/created_at)
const lightboxPhotos = citiesWithPhotos.flatMap((city) =>
  (photosByCity.get(city.id) ?? []).map((p) => ({
    id: p.id,
    r2_key_medium: p.r2_key_medium,
    r2_key_full: p.r2_key_full,
    city_name: city.name,
    capture_date: p.capture_date,
  }))
);

const ogImage = country.thumbnail_r2_key_medium
  ? `https://footsteps.gallery/i/${country.thumbnail_r2_key_medium}`
  : undefined;

// First 8 photos in DOM order load eagerly
const eagerPhotoIds = new Set(lightboxPhotos.slice(0, 8).map(p => p.id));

// ── Admin-only diary notes ─────────────────────────────────────────
// Prose is NEVER emitted to non-admin HTML — gated here, server-side.
type DiaryNote = {
  id: string;
  title: string | null;
  body: string;
  entry_date: string;
  entry_time: string | null;
  location_label: string | null;
};

let diaryNotes: DiaryNote[] = [];
if (Astro.locals.viewerIsAdmin) {
  const { results } = await env.DB
    .prepare(
      `SELECT id, title, body, entry_date, entry_time, location_label
       FROM diary_entries
       WHERE attach_type = 'country' AND attach_ref = ?
       ORDER BY entry_date DESC, created_at DESC`
    )
    .bind(country.slug)
    .all<DiaryNote>();
  diaryNotes = results ?? [];
}

function formatNoteDate(note: DiaryNote): string {
  const parts: string[] = [];
  if (note.entry_date) {
    const [y, m, d] = note.entry_date.split("-").map(Number);
    const dt = new Date(y, m - 1, d);
    const weekday = dt.toLocaleString("en-AU", { weekday: "long" });
    parts.push(`${weekday} ${dt.getDate()} ${dt.toLocaleString("en-AU", { month: "long" })}`);
  }
  if (note.entry_time) parts.push(note.entry_time);
  if (note.location_label) parts.push(note.location_label);
  return parts.join(" · ");
}

function escapeHtml(s: string): string {
  return s.replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;");
}

function bodyToHtml(raw: string): string {
  return raw
    .split(/\n{2,}/)
    .map(para => `<p>${escapeHtml(para.trim()).replace(/\n/g, "<br>")}</p>`)
    .join("");
}
---

<BaseLayout
  title={`${country.name} — Footsteps`}
  ogTitle={`${country.name} — Footsteps`}
  ogDescription={`Photographs from ${country.name}.`}
  ogImage={ogImage}
  ogType="article"
>
  {/* Load Caveat only when admin diary notes are present on this page */}
  {Astro.locals.viewerIsAdmin && diaryNotes.length > 0 && (
    <Fragment slot="head">
      <link
        href="https://fonts.googleapis.com/css2?family=Caveat:wght@400;500;600&display=swap"
        rel="stylesheet"
      />
    </Fragment>
  )}

  <!-- Country heading -->
  <div class="mx-auto max-w-7xl px-6 pb-12 pt-16">
    <a
      href="/"
      class="mb-3 inline-block text-[10px] uppercase tracking-wider text-foreground/30 transition-colors duration-200 hover:text-foreground/60"
    >
      &larr; All countries
    </a>
    <h1
      class="text-5xl font-bold md:text-7xl"
      style="font-family: 'Playfair Display', Georgia, serif;"
    >
      {country.name}
    </h1>
  </div>

  <!-- Admin-only diary notes: parchment cards pinned above the city grids -->
  {Astro.locals.viewerIsAdmin && diaryNotes.length > 0 && (
    <div class="mx-auto max-w-7xl px-6 pb-12">
      <div class="diary-notes-rail">
        {diaryNotes.map(note => (
          <article class="diary-note-card">
            <p class="diary-note-dateline">{formatNoteDate(note)}</p>
            <div class="diary-note-rule"></div>
            {note.title && <h3 class="diary-note-title">{note.title}</h3>}
            <div class="diary-note-body" set:html={bodyToHtml(note.body)} />
            <a href={`/admin/diary?entry=${note.id}`} class="diary-note-link">
              Edit in diary →
            </a>
          </article>
        ))}
      </div>
    </div>
  )}

  <!-- City sections -->
  {
    citiesWithPhotos.map((city, index) => {
      const cityPhotos = photosByCity.get(city.id) ?? [];
      return (
        <section class={`mx-auto max-w-7xl px-6${index > 0 ? " mt-16 md:mt-24" : ""}`}>
          <h2 class="mb-4 text-sm font-medium uppercase tracking-widest text-foreground/80">
            {city.name}
          </h2>
          <div class="columns-1 gap-4 sm:columns-2 lg:columns-3">
            {cityPhotos.map((photo) => (
              <div class="group mb-4 block break-inside-avoid overflow-hidden" data-lightbox-id={photo.id}>
                <img
                  src={`/i/${photo.r2_key_thumb}`}
                  alt={photo.caption ?? ""}
                  loading={eagerPhotoIds.has(photo.id) ? "eager" : "lazy"}
                  decoding="async"
                  class="block w-full h-auto"
                  {...(photo.width && photo.height ? { width: photo.width, height: photo.height } : {})}
                />
                <p class="mt-1.5 text-xs uppercase tracking-widest text-[#fafafa]/40">
                  {photo.caption}
                </p>
              </div>
            ))}
          </div>
        </section>
      );
    })
  }

  {citiesWithPhotos.length === 0 && (
    <p class="mx-auto max-w-7xl px-6 mt-16 text-base text-foreground/60">
      Photographs from {country.name} will appear here soon.
    </p>
  )}

  <Lightbox photos={lightboxPhotos} mode="public" />
</BaseLayout>

<style is:global>
  /* ── Diary note rail: flex row of parchment cards ────────────────── */
  .diary-notes-rail {
    display: flex;
    flex-wrap: wrap;
    gap: 1.25rem;
  }

  /* ── Individual parchment note card ──────────────────────────────── */
  .diary-note-card {
    flex: 1 1 20rem;
    max-width: 38rem;
    padding: 1.75rem 2rem;
    border-radius: 3px;
    background-color: hsl(40, 46%, 90%);
    background-image:
      radial-gradient(
        ellipse at center,
        transparent 62%,
        rgba(160, 130, 90, 0.22) 100%
      ),
      repeating-linear-gradient(
        to bottom,
        transparent 0px,
        transparent 3px,
        rgba(140, 110, 70, 0.048) 3px,
        rgba(140, 110, 70, 0.048) 4px
      );
    box-shadow:
      0 1px 4px rgba(0, 0, 0, 0.18),
      0 6px 28px rgba(0, 0, 0, 0.38),
      0 0 0 1px rgba(0, 0, 0, 0.06);
    color: #2a2a3a;
  }

  .diary-note-dateline {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 0.8rem;
    font-style: italic;
    color: rgba(42, 42, 58, 0.50);
    margin-bottom: 0.5rem;
  }

  .diary-note-rule {
    height: 1px;
    background-color: rgba(42, 42, 58, 0.12);
    margin-bottom: 0.75rem;
  }

  .diary-note-title {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 1.05rem;
    font-weight: 400;
    color: rgba(42, 42, 58, 0.90);
    margin-bottom: 0.5rem;
  }

  .diary-note-body {
    font-family: 'Caveat', cursive;
    font-size: 1.2rem;
    line-height: 1.6;
    color: rgba(42, 42, 58, 0.85);
  }

  .diary-note-body p {
    margin-bottom: 0.75rem;
  }

  .diary-note-body p:last-child {
    margin-bottom: 0;
  }

  .diary-note-link {
    display: inline-block;
    margin-top: 0.875rem;
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 0.72rem;
    font-style: italic;
    color: rgba(42, 42, 58, 0.35);
    text-decoration: none;
    transition: color 0.2s;
  }

  .diary-note-link:hover {
    color: rgba(42, 42, 58, 0.65);
  }

  @media (max-width: 640px) {
    .diary-note-card {
      flex: 1 1 100%;
      max-width: 100%;
      padding: 1.5rem 1.25rem;
    }
  }
</style>
