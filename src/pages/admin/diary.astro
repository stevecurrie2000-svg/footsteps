---
export const prerender = false;

import BaseLayout from "../../layouts/BaseLayout.astro";
import { requireAdmin } from "../../lib/admin-auth";

const auth = await requireAdmin(Astro.request);
if (auth instanceof Response) return auth;
---

<BaseLayout title="Diary — Admin — Footsteps" isAdmin={true}>
  <!-- PWA: manifest + theme-color, diary route only (not site-wide). -->
  <Fragment slot="head">
    <link rel="manifest" href="/manifest.webmanifest" />
    <meta name="theme-color" content="#0a0a0a" />
  </Fragment>

  <div class="mx-auto max-w-[42rem] px-6 py-12">

    <!-- Write / edit form -->
    <section id="form-section" class="mb-16">
      <div id="form-dateline" class="mb-4">
        <div class="flex flex-wrap gap-x-6 gap-y-2 font-serif text-sm text-foreground/50 italic">
          <input
            id="field-date"
            type="date"
            class="bg-transparent border-none outline-none text-foreground/70 font-serif italic text-sm w-36 cursor-pointer"
            placeholder="Date"
          />
          <input
            id="field-time"
            type="text"
            maxlength="40"
            class="bg-transparent border-none outline-none text-foreground/50 font-serif italic text-sm w-28 placeholder:text-foreground/30"
            placeholder="Time (optional)"
          />
          <input
            id="field-location"
            type="text"
            maxlength="120"
            class="bg-transparent border-none outline-none text-foreground/50 font-serif italic text-sm flex-1 min-w-[8rem] placeholder:text-foreground/30"
            placeholder="Place (optional)"
          />
        </div>
        <div class="mt-3 h-px bg-white/10"></div>
      </div>

      <input
        id="field-title"
        type="text"
        maxlength="200"
        class="w-full mb-3 bg-transparent border-none outline-none text-foreground/80 font-serif text-lg placeholder:text-foreground/25"
        placeholder="Title (optional)"
      />

      <textarea
        id="field-body"
        rows="10"
        class="w-full bg-transparent border-none outline-none resize-none text-foreground/85 text-base leading-[1.75] placeholder:text-foreground/25"
        placeholder="Begin writing…"
      ></textarea>

      <div class="mt-6 flex items-center gap-4">
        <button
          id="save-btn"
          class="rounded bg-white text-background px-5 py-2 text-sm font-medium hover:bg-white/90 transition-colors disabled:opacity-40"
        >Save entry</button>
        <button
          id="cancel-btn"
          class="hidden text-sm text-foreground/40 hover:text-foreground/70 transition-colors"
        >Cancel</button>
        <p id="form-error" class="hidden text-sm text-red-400"></p>
      </div>

      <!-- Sync status — quiet, paper-diary voice -->
      <p id="sync-status" class="mt-4 font-serif text-xs italic text-foreground/30"></p>
    </section>

    <!-- Divider -->
    <div class="mb-14 h-px bg-white/8"></div>

    <!-- Entry list -->
    <section id="list-section">
      <div id="list-loading" class="space-y-10">
        {[1, 2].map(() => (
          <div class="animate-pulse space-y-3">
            <div class="h-3 w-48 rounded bg-white/8"></div>
            <div class="h-px bg-white/8"></div>
            <div class="space-y-2">
              <div class="h-3 w-full rounded bg-white/5"></div>
              <div class="h-3 w-5/6 rounded bg-white/5"></div>
              <div class="h-3 w-3/4 rounded bg-white/5"></div>
            </div>
          </div>
        ))}
      </div>
      <p id="list-error" class="hidden text-sm text-red-400"></p>
      <div id="entries-container" class="hidden"></div>
      <div id="empty-state" class="hidden py-16 text-center">
        <p class="font-serif text-xl italic text-foreground/20">A fresh page…</p>
        <p class="mt-2 text-xs text-foreground/15">Write the first entry above.</p>
      </div>
    </section>

  </div>
</BaseLayout>

<script>
  // Offline-first (Slice D4): all reads and writes go through the local
  // IndexedDB layer; the API is reached only by the background sync engine.
  import {
    getAllEntries,
    saveEntry,
    deleteEntry,
    type DiaryEntry,
  } from "../../lib/diary-local";
  import {
    initSync,
    scheduleSync,
    refreshStatus,
    onSyncStatus,
    onEntriesChanged,
    type SyncStatus,
  } from "../../lib/diary-sync";

  let entries: DiaryEntry[] = [];
  let editingId: string | null = null;

  // ── DOM refs ────────────────────────────────────────────────────

  const fieldDate     = document.getElementById("field-date")     as HTMLInputElement;
  const fieldTime     = document.getElementById("field-time")     as HTMLInputElement;
  const fieldLocation = document.getElementById("field-location") as HTMLInputElement;
  const fieldTitle    = document.getElementById("field-title")    as HTMLInputElement;
  const fieldBody     = document.getElementById("field-body")     as HTMLTextAreaElement;
  const saveBtn       = document.getElementById("save-btn")       as HTMLButtonElement;
  const cancelBtn     = document.getElementById("cancel-btn")     as HTMLButtonElement;
  const formError     = document.getElementById("form-error")!;
  const syncStatus    = document.getElementById("sync-status")!;

  const listLoading   = document.getElementById("list-loading")!;
  const listError     = document.getElementById("list-error")!;
  const container     = document.getElementById("entries-container")!;
  const emptyState    = document.getElementById("empty-state")!;

  // ── Utilities ────────────────────────────────────────────────────

  function formatDateline(entry: DiaryEntry): string {
    const parts: string[] = [];

    if (entry.entry_date) {
      const [year, month, day] = entry.entry_date.split("-").map(Number);
      const d = new Date(year, month - 1, day);
      const weekday = d.toLocaleString("en-AU", { weekday: "long" });
      const dayNum = d.getDate();
      const monthStr = d.toLocaleString("en-AU", { month: "long" });
      parts.push(`${weekday} ${dayNum} ${monthStr}`);
    }

    if (entry.entry_time) parts.push(entry.entry_time);
    if (entry.location_label) parts.push(entry.location_label);

    return parts.join(" · ");
  }

  function escapeHtml(s: string): string {
    return s
      .replace(/&/g, "&amp;")
      .replace(/</g, "&lt;")
      .replace(/>/g, "&gt;")
      .replace(/"/g, "&quot;");
  }

  function bodyToHtml(raw: string): string {
    return raw
      .split(/\n{2,}/)
      .map(para => `<p>${escapeHtml(para.trim()).replace(/\n/g, "<br>")}</p>`)
      .join("");
  }

  // ── Render ───────────────────────────────────────────────────────

  function renderEntries(list: DiaryEntry[]) {
    container.innerHTML = "";

    if (list.length === 0) {
      container.classList.add("hidden");
      emptyState.classList.remove("hidden");
      return;
    }

    emptyState.classList.add("hidden");
    container.classList.remove("hidden");

    let currentMonthKey = "";
    let isFirstGroup = true;

    for (const entry of list) {
      const monthKey = entry.entry_date.slice(0, 7); // "YYYY-MM"

      if (monthKey !== currentMonthKey) {
        currentMonthKey = monthKey;
        const [year, month] = monthKey.split("-").map(Number);
        const label = new Date(year, month - 1, 1)
          .toLocaleString("en-AU", { month: "long", year: "numeric" });

        const heading = document.createElement("p");
        heading.className = isFirstGroup
          ? "font-serif text-xs text-foreground/25 mb-7 tracking-wide"
          : "font-serif text-xs text-foreground/25 mt-16 mb-7 tracking-wide";
        heading.textContent = label;
        container.appendChild(heading);
        isFirstGroup = false;
      }

      const article = document.createElement("article");
      article.id = `entry-${entry.id}`;
      article.dataset.id = entry.id;
      article.className = "group mb-12";

      const dateline = formatDateline(entry);
      const titleHtml = entry.title
        ? `<h2 class="mt-1 font-serif text-xl text-foreground/90">${escapeHtml(entry.title)}</h2>`
        : "";

      article.innerHTML = `
        <div class="flex items-baseline justify-between gap-4">
          <p class="font-serif text-sm italic text-foreground/45">${escapeHtml(dateline)}</p>
          <span class="flex shrink-0 gap-3 opacity-0 group-hover:opacity-100 transition-opacity">
            <button
              class="edit-btn text-xs text-foreground/25 hover:text-foreground/60 transition-colors"
              data-id="${escapeHtml(entry.id)}"
            >edit</button>
            <button
              class="delete-btn text-xs text-foreground/25 hover:text-red-400/70 transition-colors"
              data-id="${escapeHtml(entry.id)}"
            >delete</button>
          </span>
        </div>
        <div class="mt-2 h-px bg-white/10"></div>
        ${titleHtml}
        <div class="mt-4 text-[0.9375rem] leading-[1.75] text-foreground/80 prose-entry">
          ${bodyToHtml(entry.body)}
        </div>
      `;

      container.appendChild(article);
    }
  }

  // ── Load (always from the local store — instant, offline-safe) ────

  async function loadEntries() {
    try {
      entries = await getAllEntries();
      listLoading.classList.add("hidden");
      renderEntries(entries);
      scrollToPermalink();
    } catch (err: any) {
      listLoading.classList.add("hidden");
      listError.textContent = err.message;
      listError.classList.remove("hidden");
    }
  }

  // ── Form state ───────────────────────────────────────────────────

  function resetForm() {
    editingId = null;
    fieldDate.value = new Date().toISOString().slice(0, 10);
    fieldTime.value = "";
    fieldLocation.value = "";
    fieldTitle.value = "";
    fieldBody.value = "";
    saveBtn.textContent = "Save entry";
    cancelBtn.classList.add("hidden");
    formError.classList.add("hidden");
    syncFormButtons();
    fieldBody.focus();
  }

  function populateForm(entry: DiaryEntry) {
    editingId = entry.id;
    fieldDate.value = entry.entry_date;
    fieldTime.value = entry.entry_time ?? "";
    fieldLocation.value = entry.location_label ?? "";
    fieldTitle.value = entry.title ?? "";
    fieldBody.value = entry.body;
    saveBtn.textContent = "Update entry";
    cancelBtn.classList.remove("hidden");
    formError.classList.add("hidden");
    syncFormButtons();
    fieldBody.focus();
    window.scrollTo({ top: 0, behavior: "smooth" });
  }

  // ── Save (create or update) ───────────────────────────────────────

  saveBtn.addEventListener("click", async () => {
    formError.classList.add("hidden");

    const body = fieldBody.value.trim();
    const entryDate = fieldDate.value.trim();

    if (!body) {
      formError.textContent = "Body is required.";
      formError.classList.remove("hidden");
      fieldBody.focus();
      return;
    }
    if (!entryDate) {
      formError.textContent = "Date is required.";
      formError.classList.remove("hidden");
      fieldDate.focus();
      return;
    }

    saveBtn.disabled = true;
    try {
      // Write to IndexedDB + outbox; sync pushes to D1 in the background.
      await saveEntry({
        id: editingId,
        title: fieldTitle.value.trim() || null,
        body,
        entry_date: entryDate,
        entry_time: fieldTime.value.trim() || null,
        location_label: fieldLocation.value.trim() || null,
      });

      resetForm();
      await loadEntries();
      await refreshStatus();
      scheduleSync();
    } catch (err: any) {
      formError.textContent = err.message;
      formError.classList.remove("hidden");
    } finally {
      saveBtn.disabled = false;
    }
  });

  cancelBtn.addEventListener("click", resetForm);

  // ── Edit / delete (event delegation) ─────────────────────────────

  container.addEventListener("click", async (e) => {
    const editBtn = (e.target as Element).closest(".edit-btn") as HTMLElement | null;
    const deleteBtn = (e.target as Element).closest(".delete-btn") as HTMLElement | null;

    if (editBtn) {
      const id = editBtn.dataset.id!;
      const entry = entries.find(en => en.id === id);
      if (entry) populateForm(entry);
      return;
    }

    if (deleteBtn) {
      const id = deleteBtn.dataset.id!;
      if (!confirm("Delete this entry? This cannot be undone.")) return;

      deleteBtn.disabled = true;
      try {
        // Remove locally + queue a delete tombstone; sync propagates it.
        await deleteEntry(id);
        if (editingId === id) resetForm();
        await loadEntries();
        await refreshStatus();
        scheduleSync();
      } catch (err: any) {
        alert(`Delete failed: ${err.message}`);
        deleteBtn.disabled = false;
      }
    }
  });

  // Show delete button inside edit mode — injected via a second pass on the
  // article after populateForm sets editingId. Instead, wire delete from the
  // form area when in edit mode.
  saveBtn.parentElement!.addEventListener("click", async (e) => {
    const deleteBtn = (e.target as Element).closest("#inline-delete") as HTMLButtonElement | null;
    if (!deleteBtn || !editingId) return;

    if (!confirm("Delete this entry? This cannot be undone.")) return;

    deleteBtn.disabled = true;
    try {
      await deleteEntry(editingId);
      resetForm();
      await loadEntries();
      await refreshStatus();
      scheduleSync();
    } catch (err: any) {
      alert(`Delete failed: ${err.message}`);
      deleteBtn.disabled = false;
    }
  });

  // Rebuild the action row when editingId changes so "Delete" appears in edit mode
  function syncFormButtons() {
    const existingDelete = document.getElementById("inline-delete");
    if (existingDelete) existingDelete.remove();

    if (editingId) {
      const del = document.createElement("button");
      del.id = "inline-delete";
      del.type = "button";
      del.textContent = "Delete";
      del.className = "ml-auto text-sm text-red-400/70 hover:text-red-400 transition-colors";
      saveBtn.parentElement!.appendChild(del);
    }
  }

  // ── Permalink ────────────────────────────────────────────────────

  function scrollToPermalink() {
    const id = new URLSearchParams(location.search).get("entry");
    if (!id) return;
    const el = document.getElementById(`entry-${id}`);
    if (el) el.scrollIntoView({ behavior: "smooth", block: "start" });
  }

  // ── Sync status indicator (locked wording, three states) ─────────

  function renderSyncStatus(status: SyncStatus) {
    syncStatus.textContent =
      status === "syncing" ? "Syncing…"
      : status === "pending" ? "Saved on this device — will sync when online"
      : "All changes saved";
  }

  onSyncStatus(renderSyncStatus);

  // Re-render the list when the background pull merges newer server rows in
  // (e.g. first load on a fresh device, or after coming back online).
  onEntriesChanged(() => { void loadEntries(); });

  // ── Init ────────────────────────────────────────────────────────

  fieldDate.value = new Date().toISOString().slice(0, 10);

  loadEntries();
  initSync();   // initial push+pull if online; wires the 'online' event
  refreshStatus();

  // PWA: register the service worker (diary route only) so the app shell opens
  // offline. Scoped to /admin/diary — never site-wide. See public/sw.js.
  if ("serviceWorker" in navigator) {
    navigator.serviceWorker
      .register("/sw.js", { scope: "/admin/diary" })
      .catch((err) => console.error("[diary] service worker registration failed", err));
  }
</script>

<style>
  /* Paper-diary prose paragraphs */
  .prose-entry p {
    margin-bottom: 0.875rem;
  }
  .prose-entry p:last-child {
    margin-bottom: 0;
  }

  /* Hairline rule under body textarea as a subtle lined-paper nod */
  #field-body {
    background-image: repeating-linear-gradient(
      to bottom,
      transparent,
      transparent calc(1.75em - 1px),
      rgba(255,255,255,0.04) calc(1.75em - 1px),
      rgba(255,255,255,0.04) 1.75em
    );
    background-attachment: local;
    padding-top: 0.1em;
  }
</style>
