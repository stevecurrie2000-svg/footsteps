---
export const prerender = false;

import BaseLayout from "../../layouts/BaseLayout.astro";
import { requireAdmin } from "../../lib/admin-auth";

const auth = await requireAdmin(Astro.request);
if (auth instanceof Response) return auth;
const { email } = auth;
---

<BaseLayout title="Admin — Footsteps" isAdmin={true}>
  <div class="mx-auto max-w-4xl px-6 py-10">

    <div class="mb-10">
      <h1 class="text-2xl font-bold text-foreground font-heading">Admin</h1>
      <p class="mt-1 text-sm text-foreground/50">Signed in as {email}</p>
    </div>

    <!-- Stats -->
    <section class="mb-10">
      <h2 class="mb-4 text-xs font-medium uppercase tracking-widest text-foreground/40">Overview</h2>
      <div id="stats-grid" class="grid grid-cols-2 gap-3 sm:grid-cols-3 lg:grid-cols-5">
        {["photos", "countries", "last-upload", "allowed-users", "storage"].map((id) => (
          <div class="rounded border border-white/10 bg-white/3 px-4 py-4">
            <p id={`stat-label-${id}`} class="text-xs text-foreground/40 mb-1 truncate">&nbsp;</p>
            <p id={`stat-value-${id}`} class="text-lg font-medium text-foreground animate-pulse bg-white/5 rounded h-7 w-16">&nbsp;</p>
          </div>
        ))}
      </div>
      <p id="stats-error" class="hidden mt-3 text-sm text-red-400"></p>
    </section>

    <!-- Quick links -->
    <section>
      <h2 class="mb-4 text-xs font-medium uppercase tracking-widest text-foreground/40">Sections</h2>
      <div class="grid grid-cols-1 gap-3 sm:grid-cols-2">
        <a href="/admin/upload" class="group flex items-center justify-between rounded border border-white/10 bg-white/3 px-5 py-4 transition-colors hover:border-white/20 hover:bg-white/5">
          <div>
            <p class="text-sm font-medium text-foreground">Upload</p>
            <p class="mt-0.5 text-xs text-foreground/40">Add new photos to the archive</p>
          </div>
          <span class="text-foreground/20 group-hover:text-foreground/40 transition-colors text-lg">→</span>
        </a>
        <a href="/admin/photos" class="group flex items-center justify-between rounded border border-white/10 bg-white/3 px-5 py-4 transition-colors hover:border-white/20 hover:bg-white/5">
          <div>
            <p class="text-sm font-medium text-foreground">Photos</p>
            <p class="mt-0.5 text-xs text-foreground/40">Edit, reorder, or remove photos</p>
          </div>
          <span class="text-foreground/20 group-hover:text-foreground/40 transition-colors text-lg">→</span>
        </a>
        <a href="/admin/countries" class="group flex items-center justify-between rounded border border-white/10 bg-white/3 px-5 py-4 transition-colors hover:border-white/20 hover:bg-white/5">
          <div>
            <p class="text-sm font-medium text-foreground">Countries</p>
            <p class="mt-0.5 text-xs text-foreground/40">Manage country metadata</p>
          </div>
          <span class="text-foreground/20 group-hover:text-foreground/40 transition-colors text-lg">→</span>
        </a>
        <a href="/admin/access" class="group flex items-center justify-between rounded border border-white/10 bg-white/3 px-5 py-4 transition-colors hover:border-white/20 hover:bg-white/5">
          <div>
            <p class="text-sm font-medium text-foreground">Access</p>
            <p class="mt-0.5 text-xs text-foreground/40">Manage who can view private photos</p>
          </div>
          <span class="text-foreground/20 group-hover:text-foreground/40 transition-colors text-lg">→</span>
        </a>
      </div>
    </section>

  </div>
</BaseLayout>

<script>
  type DashboardData = {
    photoCount: number;
    countryCount: number;
    lastUploadIso: string | null;
    allowlistCount: number | null;
    r2BytesUsed: number;
  };

  const LABELS: Record<string, string> = {
    photos: "Photos",
    countries: "Countries",
    "last-upload": "Last upload",
    "allowed-users": "Allowed users",
    storage: "Storage used",
  };

  function formatBytes(bytes: number): string {
    if (bytes === 0) return "0 B";
    const units = ["B", "KB", "MB", "GB", "TB"];
    const i = Math.floor(Math.log(bytes) / Math.log(1024));
    return `${(bytes / Math.pow(1024, i)).toFixed(i === 0 ? 0 : 1)} ${units[i]}`;
  }

  function formatLastUpload(iso: string | null): string {
    if (!iso) return "—";
    const d = new Date(iso);
    const day = d.getDate();
    const month = d.toLocaleString("en-AU", { month: "short" });
    const year = d.getFullYear();
    const now = new Date();
    return year === now.getFullYear()
      ? `${day} ${month}`
      : `${day} ${month} ${year}`;
  }

  function setStatLabel(id: string, label: string) {
    const el = document.getElementById(`stat-label-${id}`)!;
    el.textContent = label;
  }

  function setStatValue(id: string, value: string) {
    const el = document.getElementById(`stat-value-${id}`)!;
    el.textContent = value;
    el.classList.remove("animate-pulse", "bg-white/5", "h-7", "w-16");
  }

  async function loadStats() {
    const ids = ["photos", "countries", "last-upload", "allowed-users", "storage"];
    for (const id of ids) setStatLabel(id, LABELS[id]);

    try {
      const res = await fetch("/api/admin/dashboard");
      if (!res.ok) throw new Error((await res.json() as any).error ?? `HTTP ${res.status}`);
      const data = await res.json() as DashboardData;

      setStatValue("photos", String(data.photoCount));
      setStatValue("countries", String(data.countryCount));
      setStatValue("last-upload", formatLastUpload(data.lastUploadIso));
      setStatValue("allowed-users", data.allowlistCount != null ? String(data.allowlistCount) : "—");
      setStatValue("storage", formatBytes(data.r2BytesUsed));
    } catch (err: any) {
      const errEl = document.getElementById("stats-error")!;
      errEl.textContent = `Could not load stats: ${err.message}`;
      errEl.classList.remove("hidden");
      for (const id of ids) setStatValue(id, "—");
    }
  }

  loadStats();
</script>
