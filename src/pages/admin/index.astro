---
export const prerender = false;

import BaseLayout from "../../layouts/BaseLayout.astro";
import { requireAdmin } from "../../lib/admin-auth";

const auth = requireAdmin(Astro.request);
if (auth instanceof Response) return auth;
const { email } = auth;
---

<BaseLayout title="Admin — Upload" isAdmin={true}>
  <div class="max-w-5xl mx-auto px-6 py-10 space-y-6">

    <div>
      <h1 class="text-3xl font-bold text-foreground font-heading">Admin — Upload</h1>
      <p class="mt-1 text-sm text-foreground/50">Signed in as {email}</p>
    </div>

    <div
      id="drop-zone"
      class="border-2 border-dashed border-foreground/30 rounded-lg py-16 flex items-center justify-center cursor-pointer hover:border-foreground transition-colors duration-200"
    >
      <p id="drop-zone-label" class="text-foreground/40 text-center select-none text-sm">
        Drop photos here, or click to choose files
      </p>
      <input type="file" id="file-input" multiple accept="image/jpeg,image/png" class="hidden" />
    </div>

    <div id="review-section" class="hidden space-y-4">
      <div class="overflow-x-auto">
        <table class="w-full text-sm border-collapse">
          <thead>
            <tr class="border-b border-foreground/10 text-left">
              <th class="pb-2 pr-3 font-normal text-foreground/40 w-16">Photo</th>
              <th class="pb-2 pr-3 font-normal text-foreground/40">File</th>
              <th class="pb-2 pr-3 font-normal text-foreground/40 w-44">Country</th>
              <th class="pb-2 pr-3 font-normal text-foreground/40 w-44">City</th>
              <th class="pb-2 pr-3 font-normal text-foreground/40 w-32">Audience</th>
              <th class="pb-2 font-normal text-foreground/40 w-24">Status</th>
            </tr>
          </thead>
          <tbody id="review-tbody"></tbody>
        </table>
      </div>
      <button
        id="upload-button"
        type="button"
        disabled
        class="px-6 py-2.5 rounded bg-foreground text-background font-medium text-sm disabled:opacity-30 disabled:cursor-not-allowed transition-opacity"
      >
        Upload 0 photos
      </button>
    </div>

  </div>
</BaseLayout>

<script>
  import exifr from "exifr";
  import { reverseGeocode, slugify, type GeocodeResult } from "../../lib/nominatim";

  // ── Types ──────────────────────────────────────────────────────────────────
  interface ExifResult {
    latitude?: number;
    longitude?: number;
    DateTimeOriginal?: Date;
  }

  type RowStatus = "idle" | "uploading" | "success" | "failed";

  interface RowState {
    file: File;
    thumbnailDataUrl: string;
    filename: string;
    captureDate: string | null;
    gpsLat: number | null;
    gpsLon: number | null;
    geocodedCountrySlug: string | null;
    geocodedCitySlug: string | null;
    geocodedCountryName: string | null;
    geocodedCityName: string | null;
    countrySlug: string | null;
    citySlug: string | null;
    isPublic: boolean;
    status: RowStatus;
    errorMessage: string | null;
  }

  // ── Global state ───────────────────────────────────────────────────────────
  const rows        = new Map<string, RowState>();
  const rowElements = new Map<string, HTMLTableRowElement>();
  let allCountries: { slug: string; name: string }[] = [];
  let uploadInFlight = false;

  // ── Element refs ───────────────────────────────────────────────────────────
  const dropZone      = document.getElementById("drop-zone")       as HTMLDivElement;
  const dropZoneLabel = document.getElementById("drop-zone-label") as HTMLParagraphElement;
  const fileInput     = document.getElementById("file-input")      as HTMLInputElement;
  const reviewSection = document.getElementById("review-section")  as HTMLDivElement;
  const reviewTbody   = document.getElementById("review-tbody")    as HTMLTableSectionElement;
  const uploadButton  = document.getElementById("upload-button")   as HTMLButtonElement;

  // ── Country cache ──────────────────────────────────────────────────────────
  async function loadCountries() {
    const res = await fetch("/api/admin/countries");
    if (!res.ok) return;
    const data = await res.json() as { countries: { slug: string; name: string }[] };
    allCountries = data.countries;
  }
  const countriesReady = loadCountries();

  // ── Toast ──────────────────────────────────────────────────────────────────
  function showToast(message: string) {
    const toast = document.createElement("div");
    toast.className =
      "fixed bottom-4 right-4 z-50 max-w-xs px-4 py-3 rounded shadow-lg " +
      "bg-zinc-800 border border-white/10 text-sm text-foreground " +
      "transition-opacity duration-300";
    toast.style.opacity = "0";
    toast.textContent = message;
    document.body.appendChild(toast);
    requestAnimationFrame(() => { toast.style.opacity = "1"; });
    setTimeout(() => {
      toast.style.opacity = "0";
      toast.addEventListener("transitionend", () => toast.remove(), { once: true });
    }, 4000);
  }

  // ── Nominatim queue ────────────────────────────────────────────────────────
  const geocodeQueue: (() => Promise<void>)[] = [];
  let geocodeRunning = false;

  async function drainGeocodeQueue() {
    if (geocodeRunning) return;
    geocodeRunning = true;
    let first = true;
    while (geocodeQueue.length > 0) {
      const task = geocodeQueue.shift()!;
      if (!first) await new Promise<void>(r => setTimeout(r, 1100));
      first = false;
      await task();
    }
    geocodeRunning = false;
  }

  function enqueueGeocode(rowId: string) {
    const state = rows.get(rowId);
    if (!state || state.gpsLat == null || state.gpsLon == null) return;
    const { gpsLat, gpsLon, filename } = state;

    geocodeQueue.push(async () => {
      if (!rows.has(rowId)) return;
      const result = await reverseGeocode(gpsLat, gpsLon);
      if (result.status === 'ok') {
        applyGeocodeToRow(rowId, result);
      } else if (result.status === 'partial') {
        applyPartialGeocodeToRow(rowId, result);
        showToast(`Found country for ${filename} but no city — please pick the city`);
      } else {
        showToast(`Couldn't reach geocoding service for ${filename} — pick country and city manually`);
      }
    });
    drainGeocodeQueue();
  }

  // ── Geocode application ────────────────────────────────────────────────────
  function applyGeocodeToRow(rowId: string, geo: Extract<GeocodeResult, { status: 'ok' }>) {
    const state = rows.get(rowId);
    const tr    = rowElements.get(rowId);
    if (!state || !tr) return;

    const countrySlug = slugify(geo.countryName);
    const citySlug    = geo.citySlug;

    state.geocodedCountryName = geo.countryName;
    state.geocodedCityName    = geo.cityName;
    state.geocodedCountrySlug = countrySlug;
    state.geocodedCitySlug    = citySlug;

    const countrySelect = tr.querySelector<HTMLSelectElement>(`#country-${rowId}`);
    const citySelect    = tr.querySelector<HTMLSelectElement>(`#city-${rowId}`);
    if (!countrySelect || !citySelect) return;

    Array.from(countrySelect.options)
      .filter(o => o.value.startsWith("__new__:"))
      .forEach(o => o.remove());

    const existingCountry = Array.from(countrySelect.options).find(o => o.value === countrySlug);
    if (existingCountry) {
      countrySelect.value = countrySlug;
      state.countrySlug   = countrySlug;
      void loadCitiesForRow(rowId, countrySlug, geo.cityName, citySlug);
    } else {
      const opt       = document.createElement("option");
      opt.value       = `__new__:${countrySlug}`;
      opt.textContent = `${geo.countryName} (new)`;
      countrySelect.appendChild(opt);
      countrySelect.value = `__new__:${countrySlug}`;
      state.countrySlug   = `__new__:${countrySlug}`;

      citySelect.innerHTML = "";
      citySelect.disabled  = false;
      const cityOpt        = document.createElement("option");
      cityOpt.value        = `__new__:${citySlug}`;
      cityOpt.textContent  = `${geo.cityName} (new)`;
      citySelect.appendChild(cityOpt);
      citySelect.value = `__new__:${citySlug}`;
      state.citySlug   = `__new__:${citySlug}`;

      updateRowValidation(rowId);
      updateButtonState();
    }
  }

  function applyPartialGeocodeToRow(rowId: string, geo: Extract<GeocodeResult, { status: 'partial' }>) {
    const state = rows.get(rowId);
    const tr    = rowElements.get(rowId);
    if (!state || !tr) return;

    const countrySlug = slugify(geo.countryName);
    state.geocodedCountryName = geo.countryName;
    state.geocodedCountrySlug = countrySlug;

    const countrySelect = tr.querySelector<HTMLSelectElement>(`#country-${rowId}`);
    if (!countrySelect) return;

    Array.from(countrySelect.options)
      .filter(o => o.value.startsWith("__new__:"))
      .forEach(o => o.remove());

    const existingCountry = Array.from(countrySelect.options).find(o => o.value === countrySlug);
    if (existingCountry) {
      countrySelect.value = countrySlug;
      state.countrySlug   = countrySlug;
      // Trigger city dropdown load without pre-selecting any city
      countrySelect.dispatchEvent(new Event('change'));
    } else {
      const opt       = document.createElement("option");
      opt.value       = `__new__:${countrySlug}`;
      opt.textContent = `${geo.countryName} (new)`;
      countrySelect.appendChild(opt);
      countrySelect.value = `__new__:${countrySlug}`;
      state.countrySlug   = `__new__:${countrySlug}`;
      updateRowValidation(rowId);
      updateButtonState();
    }
  }

  async function loadCitiesForRow(
    rowId: string,
    countrySlug: string,
    geocodedCityName: string,
    geocodedCitySlug: string,
  ) {
    const state = rows.get(rowId);
    const tr    = rowElements.get(rowId);
    if (!state || !tr) return;

    const citySelect = tr.querySelector<HTMLSelectElement>(`#city-${rowId}`);
    if (!citySelect) return;

    citySelect.innerHTML = "";
    citySelect.disabled  = true;
    const loading        = document.createElement("option");
    loading.value        = "";
    loading.disabled     = true;
    loading.selected     = true;
    loading.textContent  = "Loading…";
    citySelect.appendChild(loading);

    const res = await fetch(`/api/admin/cities?country=${encodeURIComponent(countrySlug)}`);
    citySelect.innerHTML = "";

    if (res.ok) {
      const data = await res.json() as { cities: { slug: string; name: string }[] };
      for (const c of data.cities) {
        const opt       = document.createElement("option");
        opt.value       = c.slug;
        opt.textContent = c.name;
        citySelect.appendChild(opt);
      }
      const existing = Array.from(citySelect.options).find(o => o.value === geocodedCitySlug);
      if (existing) {
        citySelect.value = geocodedCitySlug;
        state.citySlug   = geocodedCitySlug;
      } else {
        const newOpt        = document.createElement("option");
        newOpt.value        = `__new__:${geocodedCitySlug}`;
        newOpt.textContent  = `${geocodedCityName} (new)`;
        citySelect.appendChild(newOpt);
        citySelect.value = `__new__:${geocodedCitySlug}`;
        state.citySlug   = `__new__:${geocodedCitySlug}`;
      }
      citySelect.disabled = false;
    } else {
      const placeholder       = document.createElement("option");
      placeholder.value       = "";
      placeholder.disabled    = true;
      placeholder.selected    = true;
      placeholder.textContent = "Choose a city…";
      citySelect.appendChild(placeholder);
      state.citySlug = null;
    }

    updateRowValidation(rowId);
    updateButtonState();
  }

  // ── Validation ─────────────────────────────────────────────────────────────
  function updateRowValidation(rowId: string) {
    const state = rows.get(rowId);
    const tr    = rowElements.get(rowId);
    if (!state || !tr) return;

    const valid         = state.countrySlug != null && state.citySlug != null;
    const countrySelect = tr.querySelector<HTMLSelectElement>(`#country-${rowId}`);
    const citySelect    = tr.querySelector<HTMLSelectElement>(`#city-${rowId}`);

    if (valid) {
      tr.classList.remove("bg-red-500/5");
      countrySelect?.classList.replace("border-red-500/40", "border-white/20");
      citySelect?.classList.replace("border-red-500/40", "border-white/20");
    } else {
      tr.classList.add("bg-red-500/5");
      if (!state.countrySlug) {
        countrySelect?.classList.replace("border-white/20", "border-red-500/40");
      } else {
        countrySelect?.classList.replace("border-red-500/40", "border-white/20");
      }
      if (!state.citySlug) {
        citySelect?.classList.replace("border-white/20", "border-red-500/40");
      } else {
        citySelect?.classList.replace("border-red-500/40", "border-white/20");
      }
    }
  }

  function updateButtonState() {
    const n        = rows.size;
    const allValid = n > 0 && [...rows.values()].every(
      s => s.countrySlug != null && s.citySlug != null && s.status !== "uploading",
    );
    uploadButton.disabled    = !allValid || uploadInFlight;
    uploadButton.textContent = `Upload ${n} photo${n === 1 ? "" : "s"}`;
  }

  // ── Row removal ────────────────────────────────────────────────────────────
  function removeRow(rowId: string) {
    const tr    = rowElements.get(rowId);
    const state = rows.get(rowId);
    if (tr) {
      if (state) URL.revokeObjectURL(state.thumbnailDataUrl);
      tr.remove();
      rowElements.delete(rowId);
    }
    rows.delete(rowId);

    if (rows.size === 0) {
      reviewSection.classList.add("hidden");
      dropZone.classList.replace("py-8", "py-16");
      dropZoneLabel.textContent = "Drop photos here, or click to choose files";
      fileInput.value = "";
    }
    updateButtonState();
  }

  // ── Utility ────────────────────────────────────────────────────────────────
  function escapeHtml(str: string): string {
    return str
      .replace(/&/g, "&amp;")
      .replace(/</g, "&lt;")
      .replace(/>/g, "&gt;")
      .replace(/"/g, "&quot;");
  }

  // ── Row creation ───────────────────────────────────────────────────────────
  async function addRow(rowId: string, file: File) {
    const exifRaw = await exifr.parse(file, {
      pick: ["DateTimeOriginal", "GPSLatitude", "GPSLongitude",
             "GPSLatitudeRef", "GPSLongitudeRef"],
      gps: true,
    }).catch(() => null) as ExifResult | null;

    const captureDate      = exifRaw?.DateTimeOriginal?.toISOString() ?? null;
    const gpsLat           = exifRaw?.latitude  ?? null;
    const gpsLon           = exifRaw?.longitude ?? null;
    const thumbnailDataUrl = URL.createObjectURL(file);

    const state: RowState = {
      file,
      thumbnailDataUrl,
      filename:            file.name,
      captureDate,
      gpsLat,
      gpsLon,
      geocodedCountrySlug: null,
      geocodedCitySlug:    null,
      geocodedCountryName: null,
      geocodedCityName:    null,
      countrySlug:         null,
      citySlug:            null,
      isPublic:            false,
      status:              "idle",
      errorMessage:        null,
    };
    rows.set(rowId, state);

    // ── Build row DOM ────────────────────────────────────────────────────────
    const tr     = document.createElement("tr");
    tr.id        = `row-${rowId}`;
    tr.className = "border-b border-foreground/5 hover:bg-foreground/5 transition-colors";

    // 1. Thumbnail
    const thumbTd       = document.createElement("td");
    thumbTd.className   = "py-3 pr-3 align-top";
    const thumbWrap     = document.createElement("div");
    thumbWrap.className = "relative w-16 h-16";
    const img           = document.createElement("img");
    img.src             = thumbnailDataUrl;
    img.alt             = "";
    img.className       = "w-16 h-16 object-cover rounded";
    const removeBtn     = document.createElement("button");
    removeBtn.type      = "button";
    removeBtn.textContent = "×";
    removeBtn.className =
      "absolute -top-1 -right-1 w-4 h-4 flex items-center justify-center " +
      "rounded-full bg-black/70 text-white text-xs leading-none";
    removeBtn.addEventListener("click", () => removeRow(rowId));
    thumbWrap.appendChild(img);
    thumbWrap.appendChild(removeBtn);
    thumbTd.appendChild(thumbWrap);

    // 2. Metadata stack
    const metaTd     = document.createElement("td");
    metaTd.className = "py-3 pr-3 align-top";
    const dateStr    = captureDate
      ? new Date(captureDate).toLocaleDateString("en-GB", {
          day: "2-digit", month: "short", year: "numeric",
        })
      : "No date";
    const gpsStr   = gpsLat != null ? "📍 GPS" : "📍 No GPS";
    const fnameP   = document.createElement("p");
    fnameP.className   = "text-foreground/90 text-xs font-medium break-all";
    fnameP.textContent = file.name;
    const dateP    = document.createElement("p");
    dateP.className    = "text-foreground/50 text-xs mt-0.5";
    dateP.textContent  = `📅 ${dateStr}`;
    const gpsP     = document.createElement("p");
    gpsP.className     = "text-foreground/50 text-xs";
    gpsP.textContent   = gpsStr;
    metaTd.appendChild(fnameP);
    metaTd.appendChild(dateP);
    metaTd.appendChild(gpsP);

    // 3. Country select
    const countryTd     = document.createElement("td");
    countryTd.className = "py-3 pr-3 align-top";
    const countrySelect = document.createElement("select");
    countrySelect.id    = `country-${rowId}`;
    countrySelect.className =
      "w-full bg-zinc-900 border border-white/20 rounded px-2 py-1.5 " +
      "text-xs text-foreground focus:outline-none focus:border-foreground transition-colors";
    const ctryPlaceholder       = document.createElement("option");
    ctryPlaceholder.value       = "";
    ctryPlaceholder.disabled    = true;
    ctryPlaceholder.selected    = true;
    ctryPlaceholder.textContent = "Choose…";
    countrySelect.appendChild(ctryPlaceholder);
    for (const c of allCountries) {
      const opt       = document.createElement("option");
      opt.value       = c.slug;
      opt.textContent = c.name;
      countrySelect.appendChild(opt);
    }
    countryTd.appendChild(countrySelect);

    // 4. City select
    const cityTd     = document.createElement("td");
    cityTd.className = "py-3 pr-3 align-top";
    const citySelect = document.createElement("select");
    citySelect.id    = `city-${rowId}`;
    citySelect.disabled = true;
    citySelect.className =
      "w-full bg-zinc-900 border border-white/20 rounded px-2 py-1.5 " +
      "text-xs text-foreground disabled:opacity-40 focus:outline-none " +
      "focus:border-foreground transition-colors";
    const cityPlaceholder       = document.createElement("option");
    cityPlaceholder.value       = "";
    cityPlaceholder.disabled    = true;
    cityPlaceholder.selected    = true;
    cityPlaceholder.textContent = "Country first";
    citySelect.appendChild(cityPlaceholder);
    cityTd.appendChild(citySelect);

    // 5. Audience toggle
    const audienceTd     = document.createElement("td");
    audienceTd.className = "py-3 pr-3 align-top";
    const toggleWrap     = document.createElement("div");
    toggleWrap.className = "inline-flex rounded-full border border-white/20 overflow-hidden";
    const btnPrivate      = document.createElement("button");
    btnPrivate.type       = "button";
    btnPrivate.textContent = "Private";
    btnPrivate.className   = "px-3 py-1 text-xs font-medium bg-foreground text-background";
    const btnPublic       = document.createElement("button");
    btnPublic.type        = "button";
    btnPublic.textContent = "Public";
    btnPublic.className   = "px-3 py-1 text-xs font-medium text-foreground/40";
    toggleWrap.appendChild(btnPrivate);
    toggleWrap.appendChild(btnPublic);
    audienceTd.appendChild(toggleWrap);

    // 6. Status
    const statusTd     = document.createElement("td");
    statusTd.id        = `status-${rowId}`;
    statusTd.className = "py-3 align-top";

    tr.appendChild(thumbTd);
    tr.appendChild(metaTd);
    tr.appendChild(countryTd);
    tr.appendChild(cityTd);
    tr.appendChild(audienceTd);
    tr.appendChild(statusTd);

    rowElements.set(rowId, tr);
    reviewTbody.appendChild(tr);

    // ── Row event listeners ──────────────────────────────────────────────────
    countrySelect.addEventListener("change", async () => {
      const s   = rows.get(rowId);
      if (!s) return;
      const val = countrySelect.value;
      s.countrySlug = val || null;

      if (val.startsWith("__new__:")) {
        // Restore the geocoded __new__ city for this country
        if (s.geocodedCitySlug) {
          citySelect.innerHTML = "";
          citySelect.disabled  = false;
          const o              = document.createElement("option");
          o.value              = `__new__:${s.geocodedCitySlug}`;
          o.textContent        = `${s.geocodedCityName ?? s.geocodedCitySlug} (new)`;
          citySelect.appendChild(o);
          citySelect.value = `__new__:${s.geocodedCitySlug}`;
          s.citySlug       = `__new__:${s.geocodedCitySlug}`;
        }
        updateRowValidation(rowId);
        updateButtonState();
        return;
      }

      // Reset city and load for new country selection
      s.citySlug           = null;
      citySelect.innerHTML = "";
      citySelect.disabled  = true;
      const loadingOpt       = document.createElement("option");
      loadingOpt.value       = "";
      loadingOpt.disabled    = true;
      loadingOpt.selected    = true;
      loadingOpt.textContent = "Loading…";
      citySelect.appendChild(loadingOpt);
      updateRowValidation(rowId);
      updateButtonState();

      if (!val) return;

      const res = await fetch(`/api/admin/cities?country=${encodeURIComponent(val)}`);
      citySelect.innerHTML = "";
      const defaultOpt       = document.createElement("option");
      defaultOpt.value       = "";
      defaultOpt.disabled    = true;
      defaultOpt.selected    = true;
      defaultOpt.textContent = "Choose a city…";
      citySelect.appendChild(defaultOpt);

      if (res.ok) {
        const data = await res.json() as { cities: { slug: string; name: string }[] };
        for (const c of data.cities) {
          const opt       = document.createElement("option");
          opt.value       = c.slug;
          opt.textContent = c.name;
          citySelect.appendChild(opt);
        }
        citySelect.disabled = false;
      }
      updateRowValidation(rowId);
      updateButtonState();
    });

    citySelect.addEventListener("change", () => {
      const s = rows.get(rowId);
      if (!s) return;
      s.citySlug = citySelect.value || null;
      updateRowValidation(rowId);
      updateButtonState();
    });

    btnPrivate.addEventListener("click", () => {
      const s = rows.get(rowId);
      if (!s) return;
      s.isPublic          = false;
      btnPrivate.className = "px-3 py-1 text-xs font-medium bg-foreground text-background";
      btnPublic.className = "px-3 py-1 text-xs font-medium text-foreground/40";
    });

    btnPublic.addEventListener("click", () => {
      const s = rows.get(rowId);
      if (!s) return;
      s.isPublic          = true;
      btnPrivate.className = "px-3 py-1 text-xs font-medium text-foreground/40";
      btnPublic.className = "px-3 py-1 text-xs font-medium bg-foreground text-background";
    });

    // Show review section; compact drop zone
    reviewSection.classList.remove("hidden");
    dropZone.classList.replace("py-16", "py-8");
    dropZoneLabel.textContent = "Add more photos";

    updateRowValidation(rowId);
    updateButtonState();

    if (gpsLat != null) enqueueGeocode(rowId);
  }

  // ── File handling ──────────────────────────────────────────────────────────
  async function addFiles(filesList: FileList | null) {
    if (!filesList) return;
    await countriesReady;
    for (const file of Array.from(filesList)) {
      if (!["image/jpeg", "image/png"].includes(file.type)) continue;
      await addRow(crypto.randomUUID(), file);
    }
  }

  // ── Drop zone ──────────────────────────────────────────────────────────────
  dropZone.addEventListener("click", () => fileInput.click());

  dropZone.addEventListener("dragover", (e) => {
    e.preventDefault();
    dropZone.classList.add("border-foreground");
    dropZone.classList.remove("border-foreground/30");
  });

  dropZone.addEventListener("dragleave", () => {
    dropZone.classList.remove("border-foreground");
    dropZone.classList.add("border-foreground/30");
  });

  dropZone.addEventListener("drop", (e) => {
    e.preventDefault();
    dropZone.classList.remove("border-foreground");
    dropZone.classList.add("border-foreground/30");
    addFiles(e.dataTransfer?.files ?? null);
  });

  fileInput.addEventListener("change", function () {
    addFiles(this.files);
  });

  // ── Image resizing ─────────────────────────────────────────────────────────
  function resizeToBlob(
    img: HTMLImageElement,
    maxLongSide: number,
    quality: number,
  ): Promise<Blob> {
    return new Promise((resolve) => {
      const ratio  = Math.min(1, maxLongSide / Math.max(img.naturalWidth, img.naturalHeight));
      const w      = Math.round(img.naturalWidth  * ratio);
      const h      = Math.round(img.naturalHeight * ratio);
      const canvas = document.createElement("canvas");
      canvas.width  = w;
      canvas.height = h;
      const ctx = canvas.getContext("2d")!;
      ctx.imageSmoothingQuality = "high";
      ctx.drawImage(img, 0, 0, w, h);
      canvas.toBlob((blob) => resolve(blob!), "image/jpeg", quality);
    });
  }

  async function resizeImage(file: File) {
    const url = URL.createObjectURL(file);
    const img = new Image();
    await new Promise<void>((resolve, reject) => {
      img.onload  = () => resolve();
      img.onerror = reject;
      img.src     = url;
    });
    const [thumb, medium, full, original] = await Promise.all([
      resizeToBlob(img, 400,  0.80),
      resizeToBlob(img, 1200, 0.85),
      resizeToBlob(img, 2400, 0.90),
      resizeToBlob(img, 4000, 0.95),
    ]);
    URL.revokeObjectURL(url);
    return { thumb, medium, full, original };
  }

  // ── Row status ─────────────────────────────────────────────────────────────
  function setRowStatus(rowId: string, status: RowStatus, errorMessage?: string) {
    const state = rows.get(rowId);
    if (!state) return;
    state.status       = status;
    state.errorMessage = errorMessage ?? null;

    const statusTd = document.getElementById(`status-${rowId}`);
    if (!statusTd) return;

    if (status === "idle") {
      statusTd.innerHTML = "";
    } else if (status === "uploading") {
      statusTd.innerHTML = `<span class="text-foreground/50 text-xs">⏳</span>`;
    } else if (status === "success") {
      statusTd.innerHTML = `<span class="text-green-500 text-xs font-medium">✓</span>`;
    } else {
      const msg          = errorMessage ? escapeHtml(errorMessage) : "";
      statusTd.innerHTML =
        `<span class="text-red-500 text-xs font-medium">✗</span>` +
        (msg
          ? `<p class="text-red-400 text-xs mt-0.5 leading-tight max-w-[80px]">${msg}</p>`
          : "");
    }
  }

  // ── Upload ─────────────────────────────────────────────────────────────────
  uploadButton.addEventListener("click", async () => {
    if (uploadInFlight) return;
    uploadInFlight        = true;
    uploadButton.disabled = true;

    const toUpload = [...rows.entries()]
      .filter(([, s]) => s.status === "idle" && s.countrySlug && s.citySlug)
      .map(([id]) => id);

    let successCount = 0;
    let failCount    = 0;

    for (const rowId of toUpload) {
      const state = rows.get(rowId);
      if (!state) continue;

      setRowStatus(rowId, "uploading");

      try {
        const { thumb, medium, full, original } = await resizeImage(state.file);

        const fd = new FormData();
        fd.append("country",           state.countrySlug!);
        fd.append("city",              state.citySlug!);
        fd.append("is_public",         state.isPublic ? "1" : "0");
        fd.append("capture_date",      state.captureDate ?? "");
        fd.append("latitude",          state.gpsLat != null ? String(state.gpsLat) : "");
        fd.append("longitude",         state.gpsLon != null ? String(state.gpsLon) : "");
        fd.append("original_filename", state.filename);
        fd.append("geocoded_country",  state.geocodedCountryName ?? "");
        fd.append("geocoded_city",     state.geocodedCityName    ?? "");
        fd.append("thumb",    thumb,    `${state.filename}-thumb.jpg`);
        fd.append("medium",   medium,   `${state.filename}-medium.jpg`);
        fd.append("full",     full,     `${state.filename}-full.jpg`);
        fd.append("original", original, `${state.filename}-original.jpg`);

        const res = await fetch("/api/admin/upload", { method: "POST", body: fd });

        if (res.status === 201) {
          setRowStatus(rowId, "success");
          successCount++;
          const tr = rowElements.get(rowId);
          if (tr) {
            tr.style.opacity    = "0";
            tr.style.transition = "opacity 300ms";
          }
          setTimeout(() => removeRow(rowId), 300);
        } else {
          let msg = res.statusText;
          try {
            const body = await res.json() as { error?: string };
            if (body.error) msg = body.error;
          } catch { /* ignore */ }
          setRowStatus(rowId, "failed", msg);
          failCount++;
        }
      } catch (err) {
        const msg = err instanceof Error ? err.message : "Unknown error";
        setRowStatus(rowId, "failed", msg);
        failCount++;
      }
    }

    const parts: string[] = [];
    if (successCount > 0) parts.push(`✓ ${successCount} uploaded`);
    if (failCount    > 0) parts.push(`✗ ${failCount} failed — fix and retry`);
    if (parts.length > 0) showToast(parts.join(", "));

    uploadInFlight = false;
    updateButtonState();
  });
</script>
