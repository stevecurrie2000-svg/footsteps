---
export const prerender = false;

import { env } from "cloudflare:workers";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Lightbox from "../../../components/Lightbox.astro";
import { requirePrivateViewer } from "../../../lib/private-auth";

const auth = requirePrivateViewer(Astro.request);
if (auth instanceof Response) return auth;

const { slug } = Astro.params;

const country = await env.DB
  .prepare("SELECT id, slug, name FROM countries WHERE slug = ?")
  .bind(slug)
  .first<{ id: number; slug: string; name: string }>();

if (!country) {
  return new Response(null, { status: 404, statusText: "Not Found" });
}

const { results: cities } = await env.DB
  .prepare("SELECT id, slug, name FROM cities WHERE country_id = ? ORDER BY id")
  .bind(country.id)
  .all<{ id: number; slug: string; name: string }>();

const { results: photos } = await env.DB
  .prepare(`
    SELECT id, city_id, r2_key_thumb, r2_key_medium, r2_key_full, caption, width, height
    FROM photos
    WHERE country_id = ? AND is_public = 0
    ORDER BY city_id, capture_date, created_at
  `)
  .bind(country.id)
  .all<{ id: string; city_id: number; r2_key_thumb: string; r2_key_medium: string; r2_key_full: string; caption: string | null; width: number | null; height: number | null }>();

const photosByCity = new Map<number, typeof photos>();
for (const photo of photos) {
  const list = photosByCity.get(photo.city_id) ?? [];
  list.push(photo);
  photosByCity.set(photo.city_id, list);
}

const citiesWithPhotos = cities.filter(c => (photosByCity.get(c.id)?.length ?? 0) > 0);
const totalPhotos = photos.length;

// Build flat photos array in DOM order for lightbox navigation
const lightboxPhotos = citiesWithPhotos.flatMap((city) =>
  (photosByCity.get(city.id) ?? []).map((p) => ({
    id: p.id,
    r2_key_medium: p.r2_key_medium,
    r2_key_full: p.r2_key_full,
    city_name: city.name,
  }))
);

// First 8 photos in DOM order load eagerly
const eagerPhotoIds = new Set(lightboxPhotos.slice(0, 8).map(p => p.id));
---

<BaseLayout title={`${country.name} — Private — Footsteps`} isPrivate={true}>
  <div class="mx-auto max-w-7xl px-6 pb-12 pt-16">
    <a
      href="/private"
      class="mb-8 inline-block text-xs uppercase tracking-widest text-[#fafafa]/40 transition-colors duration-200 hover:text-[#fafafa]/70"
    >
      &larr; Private
    </a>
    <h1
      class="text-5xl font-bold md:text-7xl"
      style="font-family: 'Playfair Display', Georgia, serif;"
    >
      {country.name}
    </h1>
    <p class="mt-3 text-sm uppercase tracking-widest text-[#fafafa]/40">
      {citiesWithPhotos.length} {citiesWithPhotos.length === 1 ? "city" : "cities"} &middot; {totalPhotos} {totalPhotos === 1 ? "photograph" : "photographs"}
    </p>
  </div>

  {
    citiesWithPhotos.map((city) => {
      const cityPhotos = photosByCity.get(city.id) ?? [];
      return (
        <section class="mx-auto max-w-7xl px-6 pb-24">
          <h2
            class="mb-8 text-2xl font-bold md:text-3xl"
            style="font-family: 'Playfair Display', Georgia, serif;"
          >
            {city.name}
          </h2>
          <div class="columns-1 gap-4 sm:columns-2 lg:columns-3">
            {cityPhotos.map((photo) => (
              <div class="group mb-4 block break-inside-avoid overflow-hidden" data-lightbox-id={photo.id}>
                <img
                  src={`/i/${photo.r2_key_thumb}`}
                  alt={photo.caption ?? ""}
                  loading={eagerPhotoIds.has(photo.id) ? "eager" : "lazy"}
                  decoding="async"
                  class="block w-full h-auto"
                  {...(photo.width && photo.height ? { width: photo.width, height: photo.height } : {})}
                />
                <p class="mt-1.5 text-xs uppercase tracking-widest text-[#fafafa]/40">
                  {photo.caption}
                </p>
              </div>
            ))}
          </div>
        </section>
      );
    })
  }

  <Lightbox photos={lightboxPhotos} mode="private" />
</BaseLayout>
