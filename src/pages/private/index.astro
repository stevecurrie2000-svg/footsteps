---
export const prerender = false;

import { env } from "cloudflare:workers";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { requirePrivateViewer } from "../../lib/private-auth";

const auth = await requirePrivateViewer(Astro.request);
if (auth instanceof Response) return auth;

type CountryRow = {
  id: number;
  slug: string;
  name: string;
  thumbnail_key: string | null;
  thumbnail_width: number | null;
  thumbnail_height: number | null;
};

const { results: countries } = await env.DB
  .prepare(
    `SELECT c.id, c.slug, c.name, p.r2_key_thumb AS thumbnail_key,
            p.width AS thumbnail_width, p.height AS thumbnail_height
     FROM countries c
     LEFT JOIN photos p ON p.id = c.private_thumbnail_photo_id
     WHERE EXISTS (
       SELECT 1 FROM photos ph WHERE ph.country_id = c.id AND ph.is_public = 0
     )
     ORDER BY (
       SELECT MAX(ph2.created_at) FROM photos ph2
       WHERE ph2.country_id = c.id AND ph2.is_public = 0
     ) DESC`
  )
  .all<CountryRow>();
---

<BaseLayout title="Private — Footsteps" isPrivate={true}>
  <section class="mx-auto max-w-7xl px-6 pt-12 pb-24 md:pt-16">
    {countries.length === 0 ? (
      <p class="text-sm uppercase tracking-widest text-foreground/30">
        No private photographs yet.
      </p>
    ) : (
      <div class="grid grid-cols-1 gap-3 sm:grid-cols-2 lg:grid-cols-3 md:gap-4">
        {countries.map((country) => (
          <a
            href={`/private/countries/${country.slug}`}
            class="group relative block aspect-square overflow-hidden bg-zinc-800 transition-opacity duration-300 hover:opacity-90"
          >
            {country.thumbnail_key && (
              <img
                src={`/i/${country.thumbnail_key}`}
                alt=""
                class="absolute inset-0 h-full w-full object-cover"
                loading="eager"
                decoding="async"
                {...(country.thumbnail_width && country.thumbnail_height
                  ? { width: country.thumbnail_width, height: country.thumbnail_height }
                  : {})}
              />
            )}
            <div class="absolute inset-x-0 bottom-0 bg-gradient-to-t from-black/70 via-black/40 to-transparent p-4">
              <span class="font-sans text-sm font-medium uppercase tracking-widest text-white">
                {country.name}
              </span>
            </div>
          </a>
        ))}
      </div>
    )}
  </section>
</BaseLayout>
