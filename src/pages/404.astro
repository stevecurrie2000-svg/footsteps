---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Not Found — Footsteps">
  <div class="min-h-[60vh] flex items-center justify-center px-6 py-24">
    <div class="text-center max-w-md">
      <h1
        class="text-5xl md:text-6xl text-foreground mb-6"
        style="font-family: 'Playfair Display', Georgia, serif;"
      >
        Off the path
      </h1>
      <p class="text-foreground/60 mb-10 text-lg">
        This trail leads nowhere — but plenty more do.
      </p>
      <a
        href="/"
        class="inline-block text-foreground/80 hover:text-foreground border-b border-foreground/20 hover:border-foreground/60 pb-1 transition-colors"
      >
        Return home
      </a>
    </div>
  </div>
</BaseLayout>
