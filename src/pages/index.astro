---
import { env } from "cloudflare:workers";
import BaseLayout from "../layouts/BaseLayout.astro";

// Country grid
const { results: countries } = await env.DB
  .prepare(
    `SELECT c.id, c.slug, c.name, p.r2_key_thumb AS thumbnail_key,
            p.width AS thumbnail_width, p.height AS thumbnail_height
     FROM countries c
     LEFT JOIN photos p ON p.id = c.public_thumbnail_photo_id
     WHERE EXISTS (
       SELECT 1 FROM photos ph WHERE ph.country_id = c.id AND ph.is_public = 1
     )
     ORDER BY (
       SELECT MAX(ph2.created_at) FROM photos ph2
       WHERE ph2.country_id = c.id AND ph2.is_public = 1
     ) DESC`
  )
  .all<{ id: number; slug: string; name: string; thumbnail_key: string | null; thumbnail_width: number | null; thumbnail_height: number | null }>();

// OG cover photo
const coverPhoto = await env.DB
  .prepare("SELECT r2_key_medium FROM photos WHERE is_public = 1 ORDER BY created_at DESC LIMIT 1")
  .first<{ r2_key_medium: string }>();

const ogImage = coverPhoto
  ? `https://footsteps.gallery/i/${coverPhoto.r2_key_medium}`
  : undefined;

// Map pins — per-city centroid of public photos with GPS
const { results: pinRows } = await env.DB.prepare(`
  SELECT
    cities.id      AS city_id,
    cities.name    AS city_name,
    countries.slug AS country_slug,
    countries.name AS country_name,
    COUNT(photos.id)       AS photo_count,
    AVG(photos.latitude)   AS latitude,
    AVG(photos.longitude)  AS longitude
  FROM photos
  JOIN cities   ON photos.city_id    = cities.id
  JOIN countries ON photos.country_id = countries.id
  WHERE photos.is_public = 1
    AND photos.latitude  IS NOT NULL
    AND photos.longitude IS NOT NULL
  GROUP BY cities.id
  HAVING photo_count > 0
`).all<{
  city_id: number;
  city_name: string;
  country_slug: string;
  country_name: string;
  photo_count: number;
  latitude: number;
  longitude: number;
}>();

const pins = pinRows ?? [];

// Bounding box: start from Europe-tight, expand to include any pin outside
let swLon = -10, swLat = 35, neLon = 30, neLat = 60;
for (const pin of pins) {
  if (pin.longitude < swLon) swLon = pin.longitude;
  if (pin.latitude  < swLat) swLat = pin.latitude;
  if (pin.longitude > neLon) neLon = pin.longitude;
  if (pin.latitude  > neLat) neLat = pin.latitude;
}

// Replace with your MapTiler key from https://cloud.maptiler.com/account/keys/
// Domain-restrict to footsteps.gallery in the key settings.
// Public client-side identifier — source-control safe.
const MAPTILER_KEY = 'rnng4ZJQRqxg61gTfGU6';

const PLACEHOLDER_WIDTH  = 1200;
const PLACEHOLDER_HEIGHT = 480;
const placeholderUrl =
  `https://api.maptiler.com/maps/dark-matter/static/` +
  `[${swLon},${swLat},${neLon},${neLat}]/${PLACEHOLDER_WIDTH}x${PLACEHOLDER_HEIGHT}.webp` +
  `?key=${MAPTILER_KEY}&padding=8`;

const placeholderAlt = pins.length === 0
  ? 'Map of Europe showing photograph locations (none yet)'
  : `Map showing photograph locations in ${pins.map(p => p.city_name).join(', ')}`;
---

<BaseLayout
  title="Footsteps — Europe Photography"
  ogTitle="Footsteps"
  ogDescription="A photographer's journey through Europe."
  ogImage={ogImage}
  ogType="website"
>
  {pins.length === 0 ? (
    <section class="px-6 pt-12 md:pt-16 text-center">
      <p class="text-foreground/60">
        Photograph locations will appear here as the journey unfolds.
      </p>
    </section>
  ) : (
    <section class="px-6 pt-12 md:pt-16" aria-labelledby="map-heading">
      <h2 id="map-heading" class="sr-only">Photograph locations</h2>

      <div
        id="map-container"
        class="relative mx-auto max-w-7xl overflow-hidden rounded-sm bg-zinc-900"
        style={`aspect-ratio: ${PLACEHOLDER_WIDTH} / ${PLACEHOLDER_HEIGHT};`}
        data-sw-lon={swLon}
        data-sw-lat={swLat}
        data-ne-lon={neLon}
        data-ne-lat={neLat}
      >
        <!-- Layer 0: static placeholder image -->
        <img
          id="map-placeholder"
          src={placeholderUrl}
          alt={placeholderAlt}
          width={PLACEHOLDER_WIDTH}
          height={PLACEHOLDER_HEIGHT}
          class="absolute inset-0 h-full w-full object-cover transition-opacity duration-300"
          loading="lazy"
          decoding="async"
        />

        <!-- Layer 1: CSS-positioned dot anchors (navigate without JS) -->
        <div id="pin-overlay" class="absolute inset-0 transition-opacity duration-300">
          {pins.map(pin => {
            const xPercent = ((pin.longitude - swLon) / (neLon - swLon)) * 100;
            const yPercent = ((neLat - pin.latitude) / (neLat - swLat)) * 100;
            return (
              <a
                href={`/countries/${pin.country_slug}`}
                class="group absolute z-10 -translate-x-1/2 -translate-y-1/2"
                style={`left: ${xPercent.toFixed(3)}%; top: ${yPercent.toFixed(3)}%;`}
                aria-label={`View photographs from ${pin.city_name} (${pin.photo_count} photograph${pin.photo_count === 1 ? '' : 's'})`}
                data-pin-city={pin.city_name}
                data-pin-count={pin.photo_count}
                data-pin-country={pin.country_slug}
                data-pin-lat={pin.latitude}
                data-pin-lon={pin.longitude}
              >
                <span class="block h-2.5 w-2.5 rounded-full bg-foreground shadow-[0_0_0_4px_rgba(250,250,250,0.15)] transition-all duration-150 group-hover:h-3.5 group-hover:w-3.5" />
                <span class="pointer-events-none absolute bottom-full left-1/2 mb-2 -translate-x-1/2 whitespace-nowrap rounded bg-black/90 px-2 py-1 text-xs font-medium uppercase tracking-widest text-foreground opacity-0 transition-opacity duration-150 group-hover:opacity-100 group-focus:opacity-100">
                  {pin.city_name}{pin.photo_count > 1 ? ` · ${pin.photo_count}` : ''}
                </span>
              </a>
            );
          })}
        </div>

        <!-- Layer 2: MapLibre mount point (hydrated on scroll/interaction) -->
        <div
          id="maplibre-mount"
          class="absolute inset-0 opacity-0 transition-opacity duration-300 pointer-events-none"
          aria-hidden="true"
        ></div>
      </div>

      <!-- Screen reader + no-JS navigation list -->
      <ul class="sr-only">
        {pins.map(pin => (
          <li>
            <a href={`/countries/${pin.country_slug}`}>
              Photographs from {pin.city_name}, {pin.country_name}
              ({pin.photo_count} photograph{pin.photo_count === 1 ? '' : 's'})
            </a>
          </li>
        ))}
      </ul>
    </section>
  )}

  <section class="mx-auto max-w-7xl px-6 pt-12 pb-24 md:pt-16">
    <div class="grid grid-cols-1 gap-3 sm:grid-cols-2 lg:grid-cols-3 md:gap-4">
      {
        countries.map((country) => (
          <a
            href={`/countries/${country.slug}`}
            class="group relative block aspect-square overflow-hidden bg-zinc-800 transition-opacity duration-300 hover:opacity-90"
          >
            {country.thumbnail_key && (
              <img
                src={`/i/${country.thumbnail_key}`}
                alt=""
                class="absolute inset-0 h-full w-full object-cover"
                loading="eager"
                decoding="async"
                {...(country.thumbnail_width && country.thumbnail_height
                  ? { width: country.thumbnail_width, height: country.thumbnail_height }
                  : {})}
              />
            )}
            <div class="absolute inset-x-0 bottom-0 bg-gradient-to-t from-black/70 via-black/40 to-transparent p-4">
              <span class="font-sans text-sm font-medium uppercase tracking-widest text-white">
                {country.name}
              </span>
            </div>
          </a>
        ))
      }
    </div>
  </section>
</BaseLayout>

<script>
  const MAPTILER_KEY = 'rnng4ZJQRqxg61gTfGU6';

  const container = document.getElementById('map-container') as HTMLElement | null;
  const mount = document.getElementById('maplibre-mount') as HTMLElement | null;
  const pinAnchors = container?.querySelectorAll<HTMLAnchorElement>('a[data-pin-city]');

  if (container && mount && pinAnchors && pinAnchors.length > 0) {
    let hydrated = false;

    async function hydrateMap() {
      if (hydrated) return;
      hydrated = true;

      // Dynamic import — maplibre-gl lands in a separate chunk, not the initial bundle
      const maplibregl = (await import('maplibre-gl')).default;

      // Inject MapLibre CSS on demand
      const link = document.createElement('link');
      link.rel = 'stylesheet';
      link.href = 'https://unpkg.com/maplibre-gl@4.7.1/dist/maplibre-gl.css';
      document.head.appendChild(link);

      // One frame for the stylesheet to apply before measuring
      await new Promise<void>(r => requestAnimationFrame(() => r()));

      const pins = Array.from(pinAnchors).map(a => ({
        lon:         parseFloat(a.dataset.pinLon     ?? '0'),
        lat:         parseFloat(a.dataset.pinLat     ?? '0'),
        cityName:    a.dataset.pinCity    ?? '',
        countrySlug: a.dataset.pinCountry ?? '',
        count:       parseInt(a.dataset.pinCount ?? '0', 10),
      }));

      const bounds: [[number, number], [number, number]] = [
        [parseFloat(container.dataset.swLon ?? '-10'), parseFloat(container.dataset.swLat ?? '35')],
        [parseFloat(container.dataset.neLon ?? '30'),  parseFloat(container.dataset.neLat ?? '60')],
      ];

      const map = new maplibregl.Map({
        container: 'maplibre-mount',
        style: `https://api.maptiler.com/maps/dark-matter/style.json?key=${MAPTILER_KEY}`,
        bounds,
        fitBoundsOptions: { padding: 40 },
        interactive: true,
        attributionControl: true,
      });

      map.on('load', () => {
        for (const pin of pins) {
          const el = document.createElement('a');
          el.href = `/countries/${pin.countrySlug}`;
          el.setAttribute('aria-label', `View photographs from ${pin.cityName}`);
          el.style.cssText =
            'display:block;width:10px;height:10px;border-radius:50%;' +
            'background:#fafafa;box-shadow:0 0 0 4px rgba(250,250,250,0.15);cursor:pointer;';

          new maplibregl.Marker({ element: el })
            .setLngLat([pin.lon, pin.lat])
            .setPopup(
              new maplibregl.Popup({ offset: 12, closeButton: false })
                .setHTML(
                  `<span style="font-size:11px;text-transform:uppercase;letter-spacing:0.1em">` +
                  `${pin.cityName}${pin.count > 1 ? ` · ${pin.count}` : ''}</span>`
                )
            )
            .addTo(map);
        }

        // Cross-fade: MapLibre in, static layers out
        mount.style.opacity = '1';
        mount.style.pointerEvents = 'auto';
        const placeholder = document.getElementById('map-placeholder');
        const overlay     = document.getElementById('pin-overlay');
        if (placeholder) placeholder.style.opacity = '0';
        if (overlay)     overlay.style.opacity = '0';
      });
    }

    // Hydrate on scroll-into-view (200px pre-trigger)
    const observer = new IntersectionObserver(entries => {
      if (entries[0].isIntersecting) {
        hydrateMap();
        observer.disconnect();
      }
    }, { rootMargin: '200px' });
    observer.observe(container);

    // Also hydrate on first pointer interaction with the map area
    container.addEventListener('pointerdown', hydrateMap, { once: true });
  }
</script>
