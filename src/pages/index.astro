---
import { env } from "cloudflare:workers";
import BaseLayout from "../layouts/BaseLayout.astro";

// Country grid
const { results: countries } = await env.DB
  .prepare(
    `SELECT c.id, c.slug, c.name, p.r2_key_thumb AS thumbnail_key,
            p.width AS thumbnail_width, p.height AS thumbnail_height
     FROM countries c
     LEFT JOIN photos p ON p.id = c.public_thumbnail_photo_id
     WHERE EXISTS (
       SELECT 1 FROM photos ph WHERE ph.country_id = c.id AND ph.is_public = 1
     )
     ORDER BY (
       SELECT MAX(ph2.created_at) FROM photos ph2
       WHERE ph2.country_id = c.id AND ph2.is_public = 1
     ) DESC`
  )
  .all<{ id: number; slug: string; name: string; thumbnail_key: string | null; thumbnail_width: number | null; thumbnail_height: number | null }>();

// OG cover photo
const coverPhoto = await env.DB
  .prepare("SELECT r2_key_medium FROM photos WHERE is_public = 1 ORDER BY created_at DESC LIMIT 1")
  .first<{ r2_key_medium: string }>();

const ogImage = coverPhoto
  ? `https://footsteps.gallery/i/${coverPhoto.r2_key_medium}`
  : undefined;

// Map pins — one per city that has coordinates and at least one public photo
const { results: pinRows } = await env.DB.prepare(`
  SELECT
    cities.id        AS city_id,
    cities.name      AS city_name,
    cities.latitude,
    cities.longitude,
    countries.slug   AS country_slug,
    countries.name   AS country_name,
    COUNT(photos.id) AS photo_count
  FROM cities
  JOIN countries ON cities.country_id = countries.id
  JOIN photos    ON photos.city_id    = cities.id
  WHERE photos.is_public = 1
    AND cities.latitude  IS NOT NULL
    AND cities.longitude IS NOT NULL
  GROUP BY cities.id
  HAVING photo_count > 0
`).all<{
  city_id: number;
  city_name: string;
  country_slug: string;
  country_name: string;
  photo_count: number;
  latitude: number;
  longitude: number;
}>();

const pins = pinRows ?? [];

const mapLabel = pins.length === 0
  ? 'Map of Europe showing photograph locations (none yet)'
  : `Map showing photograph locations in ${pins.map(p => p.city_name).join(', ')}`;

const pinsJson = JSON.stringify(pins.map(p => ({
  lat: p.latitude,
  lon: p.longitude,
  cityName: p.city_name,
  countrySlug: p.country_slug,
  count: p.photo_count,
})));
---

<BaseLayout
  title="Footsteps — Europe Photography"
  ogTitle="Footsteps"
  ogDescription="A photographer's journey through Europe."
  ogImage={ogImage}
  ogType="website"
>
  {pins.length === 0 ? (
    <section class="px-6 pt-12 md:pt-16 text-center">
      <p class="text-foreground/60">
        Photograph locations will appear here as the journey unfolds.
      </p>
    </section>
  ) : (
    <section class="px-6 pt-12 md:pt-16" aria-labelledby="map-heading">
      <h2 id="map-heading" class="sr-only">Photograph locations</h2>

      <div
        id="map-container"
        role="region"
        aria-label={mapLabel}
        class="relative mx-auto max-w-7xl overflow-hidden rounded-sm bg-zinc-900"
        style="aspect-ratio: 1200 / 480;"
        data-pins={pinsJson}
      >
        <div id="maplibre-mount" class="absolute inset-0 h-full w-full"></div>
      </div>

      <!-- Screen reader + no-JS navigation list -->
      <ul class="sr-only">
        {pins.map(pin => (
          <li>
            <a href={`/countries/${pin.country_slug}`}>
              Photographs from {pin.city_name}, {pin.country_name}
              ({pin.photo_count} photograph{pin.photo_count === 1 ? '' : 's'})
            </a>
          </li>
        ))}
      </ul>
    </section>
  )}

  <section class="mx-auto max-w-7xl px-6 pt-12 pb-24 md:pt-16">
    <div class="grid grid-cols-1 gap-3 sm:grid-cols-2 lg:grid-cols-3 md:gap-4">
      {
        countries.map((country) => (
          <a
            href={`/countries/${country.slug}`}
            class="group relative block aspect-square overflow-hidden bg-zinc-800 transition-opacity duration-300 hover:opacity-90"
          >
            {country.thumbnail_key && (
              <img
                src={`/i/${country.thumbnail_key}`}
                alt=""
                class="absolute inset-0 h-full w-full object-cover"
                loading="eager"
                decoding="async"
                {...(country.thumbnail_width && country.thumbnail_height
                  ? { width: country.thumbnail_width, height: country.thumbnail_height }
                  : {})}
              />
            )}
            <div class="absolute inset-x-0 bottom-0 bg-gradient-to-t from-black/70 via-black/40 to-transparent p-4">
              <span class="font-sans text-sm font-medium uppercase tracking-widest text-white">
                {country.name}
              </span>
            </div>
          </a>
        ))
      }
    </div>
  </section>
</BaseLayout>

<script>
  const MAPTILER_KEY = 'rnng4ZJQRqxg61gTfGU6';
  const MAP_STYLE_ID = 'basic-v2-dark';

  const container = document.getElementById('map-container') as HTMLElement | null;

  if (container) {
    const pins = JSON.parse(container.dataset.pins ?? '[]') as {
      lat: number; lon: number; cityName: string; countrySlug: string; count: number;
    }[];

    const geojson = {
      type: 'FeatureCollection' as const,
      features: pins.map(p => ({
        type: 'Feature' as const,
        geometry: { type: 'Point' as const, coordinates: [p.lon, p.lat] as [number, number] },
        properties: { cityName: p.cityName, countrySlug: p.countrySlug, photoCount: p.count },
      })),
    };

    (async () => {
      const maplibregl = (await import('maplibre-gl')).default;

      const link = document.createElement('link');
      link.rel = 'stylesheet';
      link.href = 'https://unpkg.com/maplibre-gl@4.7.1/dist/maplibre-gl.css';
      document.head.appendChild(link);

      await new Promise<void>(r => requestAnimationFrame(() => r()));

      const map = new maplibregl.Map({
        container: 'maplibre-mount',
        style: `https://api.maptiler.com/maps/${MAP_STYLE_ID}/style.json?key=${MAPTILER_KEY}`,
        attributionControl: false,
        interactive: true,
        renderWorldCopies: false,
      });

      map.fitBounds([[-170, -55], [180, 75]], {
        padding: { bottom: 50, top: 30, left: 30, right: 30 },
        duration: 0,
      });

      map.addControl(
        new maplibregl.AttributionControl({ compact: true }),
        'bottom-left',
      );

      map.addControl(
        new maplibregl.NavigationControl({ showCompass: false, showZoom: true, visualizePitch: false }),
        'top-right',
      );

      class ResetViewControl {
        private _map: any;
        private _container!: HTMLDivElement;

        onAdd(m: any) {
          this._map = m;
          const btn = document.createElement('button');
          btn.className = 'maplibregl-ctrl-icon footsteps-reset-btn';
          btn.type = 'button';
          btn.setAttribute('aria-label', 'Reset to world view');
          btn.title = 'Reset to world view';
          btn.innerHTML = '🌍';
          btn.addEventListener('click', () => m.easeTo({ center: [20, 30], zoom: 1, duration: 600 }));
          this._container = document.createElement('div');
          this._container.className = 'maplibregl-ctrl maplibregl-ctrl-group';
          this._container.appendChild(btn);
          return this._container;
        }
        onRemove() {
          this._container?.parentNode?.removeChild(this._container);
          this._map = undefined;
        }
      }

      map.addControl(new ResetViewControl(), 'top-right');

      map.on('load', () => {
        map.addSource('photos', {
          type: 'geojson',
          data: geojson,
          cluster: true,
          clusterMaxZoom: 6,
          clusterRadius: 40,
        });

        map.addLayer({
          id: 'clusters',
          type: 'circle',
          source: 'photos',
          filter: ['has', 'point_count'],
          paint: {
            'circle-color': '#1a1a1a',
            'circle-stroke-color': '#fafafa',
            'circle-stroke-opacity': 0.6,
            'circle-radius': ['step', ['get', 'point_count'], 16, 5, 22, 15, 28],
            'circle-stroke-width': ['step', ['get', 'point_count'], 1.5, 5, 2, 15, 2.5],
          },
        });

        map.addLayer({
          id: 'cluster-count',
          type: 'symbol',
          source: 'photos',
          filter: ['has', 'point_count'],
          layout: {
            'text-field': ['get', 'point_count_abbreviated'],
            'text-font': ['Noto Sans Bold'],
            'text-size': 12,
            'text-allow-overlap': true,
          },
          paint: { 'text-color': '#fafafa' },
        });

        map.addLayer({
          id: 'unclustered-point',
          type: 'circle',
          source: 'photos',
          filter: ['!', ['has', 'point_count']],
          paint: {
            'circle-color': '#fafafa',
            'circle-radius': 5,
            'circle-stroke-color': 'rgba(250, 250, 250, 0.2)',
            'circle-stroke-width': 4,
          },
        });

        const popup = new maplibregl.Popup({
          closeButton: false,
          closeOnClick: false,
          offset: 10,
          className: 'footsteps-pin-popup',
        });

        map.on('click', 'clusters', async (e: any) => {
          const features = map.queryRenderedFeatures(e.point, { layers: ['clusters'] });
          if (!features.length) return;
          const clusterId = features[0].properties.cluster_id;
          const zoom = await (map.getSource('photos') as any).getClusterExpansionZoom(clusterId);
          map.easeTo({ center: (features[0].geometry as any).coordinates, zoom, duration: 600 });
        });

        map.on('click', 'unclustered-point', (e: any) => {
          const props = e.features?.[0]?.properties;
          if (props?.countrySlug) window.location.href = `/countries/${props.countrySlug}`;
        });

        map.on('mouseenter', 'unclustered-point', (e: any) => {
          map.getCanvas().style.cursor = 'pointer';
          const f = e.features?.[0];
          if (!f) return;
          const { cityName, photoCount } = f.properties;
          const label = `${cityName} — ${photoCount} photo${photoCount === 1 ? '' : 's'}`;
          popup.setLngLat(f.geometry.coordinates).setText(label).addTo(map);
        });

        map.on('mouseleave', 'unclustered-point', () => {
          map.getCanvas().style.cursor = '';
          popup.remove();
        });

        map.on('mouseenter', 'clusters', () => { map.getCanvas().style.cursor = 'pointer'; });
        map.on('mouseleave', 'clusters', () => { map.getCanvas().style.cursor = ''; });
      });
    })();
  }
</script>
