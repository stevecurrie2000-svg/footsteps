---
import BaseLayout from "../layouts/BaseLayout.astro";
import "../styles/global.css";

const { env } = Astro.locals.runtime;

const { results: countries } = await env.DB
  .prepare("SELECT id, slug, name FROM countries ORDER BY sort_order")
  .all<{ id: number; slug: string; name: string }>();
---

<BaseLayout title="Footsteps — Europe Photography">
  <!-- Hero -->
  <section class="px-6 py-24 text-center">
    <h1
      class="mb-4 text-6xl font-bold md:text-8xl"
      style="font-family: 'Playfair Display', Georgia, serif;"
    >
      Footsteps
    </h1>
  </section>

  <!-- Country Grid -->
  <section class="mx-auto max-w-7xl px-6 pb-24">
    <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {
        countries.map((country) => (
          <a
            href={`/countries/${country.slug}`}
            class="group relative block aspect-square overflow-hidden bg-zinc-800 transition-opacity duration-300 hover:opacity-90"
          >
            <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-transparent to-transparent" />
            <div class="absolute bottom-0 left-0 p-6">
              <h2
                class="text-2xl font-bold text-white"
                style="font-family: 'Playfair Display', Georgia, serif;"
              >
                {country.name}
              </h2>
            </div>
          </a>
        ))
      }
    </div>
  </section>
</BaseLayout>
